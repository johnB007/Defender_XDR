          {
            "type": 3,
            "name": "correlation-ti-url-matches",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIUrl = ThreatIntelIndicators\n| where TimeGenerated > ago(30d) and IsActive == true\n| where ObservableKey == \"url:value\"\n| summarize arg_max(TimeGenerated, Confidence, Tags, Pattern, ValidUntil, Id, SourceSystem) by ObservableValue\n| project Url = tolower(ObservableValue), Confidence = toint(Confidence), Tags = strcat(tostring(SourceSystem), \" | \", tostring(Tags)), Pattern = tostring(Pattern), ValidUntil, IndicatorId = tostring(Id)\n| extend Host = tolower(extract(@'^(?:https?://)?([^/:?]+)', 1, Url));\nlet ZeekDns = ZeekLogs_CL\n| where logType_s == \"dns\" and isnotempty(dns_query_s) and dns_query_s != \"-\"\n| extend Host = tolower(dns_query_s)\n| summarize ZeekDnsHits = count(), ZeekDnsClients = make_set(src_ip_s, 10), LastZeekDns = max(TimeGenerated) by Host;\nlet ZeekSsl = ZeekLogs_CL\n| where logType_s == \"ssl\"\n| extend f = split(_raw_s, \"\\t\")\n| extend Host = tolower(tostring(f[9]))\n| where isnotempty(Host) and Host != \"-\"\n| summarize ZeekSslHits = count(), ZeekSslClients = make_set(src_ip_s, 10), LastZeekSsl = max(TimeGenerated) by Host;\nlet ZeekHttp = ZeekLogs_CL\n| where logType_s == \"http\"\n| extend f = split(_raw_s, \"\\t\")\n| extend Host = tolower(tostring(f[8]))\n| where isnotempty(Host) and Host != \"-\"\n| summarize ZeekHttpHits = count(), ZeekHttpClients = make_set(src_ip_s, 10), LastZeekHttp = max(TimeGenerated) by Host;\nlet DnsSinkhole = PiholeDNS_CL\n| extend Host = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|forwarded|reply)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s)))\n| extend ClientIP = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s)\n| where isnotempty(Host) and Host != \"-\"\n| summarize PiHoleHits = count(), PiHoleClients = make_set(ClientIP, 10), LastPiHole = max(TimeGenerated) by Host;\nlet MdeUrls = DeviceNetworkEvents\n| where isnotempty(RemoteUrl)\n| extend Host = tolower(extract(@'^(?:https?://)?([^/:?]+)', 1, RemoteUrl))\n| where isnotempty(Host)\n| summarize MdeHits = count(), MdeDevices = make_set(DeviceName, 10), LastMde = max(TimeGenerated) by Host;\nTIUrl\n| join kind=leftouter ZeekDns on Host\n| join kind=leftouter ZeekSsl on Host\n| join kind=leftouter ZeekHttp on Host\n| join kind=leftouter DnsSinkhole on Host\n| join kind=leftouter MdeUrls on Host\n| extend ZeekDnsHits = coalesce(ZeekDnsHits, 0), ZeekSslHits = coalesce(ZeekSslHits, 0), ZeekHttpHits = coalesce(ZeekHttpHits, 0), PiHoleHits = coalesce(PiHoleHits, 0), MdeHits = coalesce(MdeHits, 0)\n| extend NonMdeHits = ZeekDnsHits + ZeekSslHits + ZeekHttpHits + PiHoleHits\n| where NonMdeHits > 0 or MdeHits > 0\n| extend Sources = strcat(iff(ZeekDnsHits>0,\"ZeekDNS \",\"\"), iff(ZeekSslHits>0,\"ZeekSSL \",\"\"), iff(ZeekHttpHits>0,\"ZeekHTTP \",\"\"), iff(PiHoleHits>0,\"DnsSinkhole \",\"\"), iff(MdeHits>0,\"MDE\",\"\"))\n| extend Clients = array_concat(coalesce(ZeekDnsClients, dynamic([])), coalesce(ZeekSslClients, dynamic([])), coalesce(ZeekHttpClients, dynamic([])), coalesce(PiHoleClients, dynamic([])))\n| extend LastSeen = max_of(coalesce(LastZeekDns, datetime(1970-01-01)), coalesce(LastZeekSsl, datetime(1970-01-01)), coalesce(LastZeekHttp, datetime(1970-01-01)), coalesce(LastPiHole, datetime(1970-01-01)), coalesce(LastMde, datetime(1970-01-01)))\n| project Url, Host, Confidence, Tags, Sources, NonMdeHits, MdeHits, ZeekDnsHits, ZeekSslHits, ZeekHttpHits, PiHoleHits, Clients, MdeDevices, LastSeen, ValidUntil, Pattern, IndicatorId\n| sort by Confidence desc, NonMdeHits desc\n| top 200 by Confidence",
              "size": 0,
              "title": "TI URL Matches — TII vs Zeek HTTP + MDE URLs (TI=30d)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Confidence",
