          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIip = ThreatIntelIndicators | where TimeGenerated > ago(24h) and IsActive == true | where ObservableKey in (\"network-traffic:src_ref.value\",\"network-traffic:dst_ref.value\",\"ipv4-addr:value\") | distinct ObservableValue;\nlet TIdom = ThreatIntelIndicators | where TimeGenerated > ago(24h) and IsActive == true | where ObservableKey == \"domain-name:value\" | distinct tolower(ObservableValue);\nlet zeekConn = ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"conn\" | extend Ext = case(not(ipv4_is_private(dst_ip_s)), dst_ip_s, src_ip_s), Int = case(ipv4_is_private(src_ip_s), src_ip_s, dst_ip_s) | where Ext in (TIip) and isnotempty(Int) | summarize IpHits = count() by Int;\nlet pihole = PiholeDNS_CL | where TimeGenerated > ago(24h) | extend d = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|forwarded|reply)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s))), Int = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s) | where d in (TIdom) and isnotempty(Int) | summarize DomainHits = count() by Int;\nlet zeekDns = ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"dns\" | extend d = tolower(dns_query_s), Int = src_ip_s | where d in (TIdom) and isnotempty(Int) | summarize ZeekDnsHits = count() by Int;\nlet MdeIdent = DeviceNetworkInfo | summarize arg_max(Timestamp, *) by IPAddresses | mv-expand todynamic(IPAddresses) | extend Int = tostring(IPAddresses.IPAddress) | where ipv4_is_private(Int) | project Int, MdeDevice = DeviceName, MdeMac = MacAddress;\nlet DhcpIdent = ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"dhcp\" | extend f = split(_raw_s, \"\\t\") | extend Int = tostring(f[7]), DhcpHost = tostring(f[10]), DhcpMac = tostring(f[3]) | where isnotempty(Int) | summarize arg_max(TimeGenerated, *) by Int | project Int, DhcpHost, DhcpMac;\nunion zeekConn, pihole, zeekDns\n| summarize IpHits = sum(coalesce(IpHits,0)), DomainHits = sum(coalesce(DomainHits,0)), ZeekDnsHits = sum(coalesce(ZeekDnsHits,0)) by Int\n| extend TotalHits = IpHits + DomainHits + ZeekDnsHits\n| join kind=leftouter MdeIdent on Int\n| join kind=leftouter DhcpIdent on Int\n| extend ClientName = coalesce(MdeDevice, DhcpHost, Int)\n| extend ClientMac = coalesce(MdeMac, DhcpMac, \"\")\n| extend ClientType = case(isnotempty(MdeDevice), \"MDE Managed\", isnotempty(DhcpHost), \"Non-MDE (DHCP)\", \"Non-MDE (Unknown)\")\n| project ClientType, ClientName, InternalIP = Int, ClientMac, IpHits, DomainHits, ZeekDnsHits, TotalHits\n| sort by TotalHits desc\n| top 50 by TotalHits",
              "size": 0,
              "title": "Top Threatened Internal Clients (24h) — TI hits attributed to MDE-managed and non-MDE devices",
              "noDataMessage": "No internal clients touched TI in last 24h",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ClientType",
                    "formatter": 11,
                    "formatOptions": {
                      "palette": "categoricalGreen"
                    }
                  },
                  {
                    "columnMatch": "TotalHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redBright"
                    }
                  },
                  {
                    "columnMatch": "IpHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "coral"
                    }
                  },
                  {
                    "columnMatch": "DomainHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "coral"
                    }
                  },
                  {
                    "columnMatch": "ZeekDnsHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "coral"
                    }
                  }
                ]
              }
            },
            "name": "correlation-top-clients"
          }
        ]
      }
    },
    {
      "type": 12,
      "name": "group-hunting",
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Hunting"
      },
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Threat Hunting\n\n**Proactive threat hunting: anomalous behaviors, beaconing detection, lateral movement, and data exfiltration indicators**",
              "style": "info"
            },
            "name": "text-hunting-header"
          },
          {
            "type": 3,
            "name": "hunting-beaconing-detection",
            "content": {
              "version": "KqlItem/1.0",
              "query": "NetFlow_CL\n| extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n| where SrcIPStr startswith \"192.168.\" or SrcIPStr startswith \"10.\"\n| where DstIPStr !startswith \"192.168.\" and DstIPStr !startswith \"10.\"\n| summarize ConnectionTimes = make_list(TimeGenerated, 1000) by SrcIPStr, DstIPStr, DstPort\n| where array_length(ConnectionTimes) >= 10\n| extend SortedTimes = array_sort_asc(ConnectionTimes)\n| mv-apply SortedTimes to typeof(datetime) on (\n    extend prev_t = prev(SortedTimes)\n    | where isnotempty(prev_t)\n    | extend interval_sec = datetime_diff('second', SortedTimes, prev_t)\n    | summarize AvgInterval = avg(interval_sec), StdDevInterval = stdev(interval_sec), Connections = count() + 1\n)\n| where StdDevInterval > 0 and AvgInterval > 0\n| extend CoeffVariation = StdDevInterval / AvgInterval\n| where CoeffVariation < 0.3 and Connections >= 10\n| extend BeaconScore = round((1.0 - CoeffVariation) * 100, 1)\n| sort by BeaconScore desc\n| take 50\n| project SourceIP = SrcIPStr, DestIP = DstIPStr, DstPort, Connections, AvgInterval_sec = round(AvgInterval, 0), BeaconScore",
              "size": 0,
              "title": "Potential Beaconing Activity (Regular Interval Connections)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "BeaconScore",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redBright"
                    }
                  },
                  {
                    "columnMatch": "Connections",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "hunting-large-data-transfers",
            "content": {
              "version": "KqlItem/1.0",
              "query": "NetFlow_CL\n| extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n| extend BytesInt = toint(Bytes)\n| where SrcIPStr startswith \"192.168.\" or SrcIPStr startswith \"10.\"\n| where DstIPStr !startswith \"192.168.\" and DstIPStr !startswith \"10.\"\n| summarize TotalBytes = sum(BytesInt), Connections = count(), FirstSeen = min(TimeGenerated), LastSeen = max(TimeGenerated) by SrcIPStr, DstIPStr, DstPort\n| extend TotalMB = round(TotalBytes / 1048576.0, 2)\n| where TotalMB > 100\n| sort by TotalMB desc\n| take 50\n| project SourceIP = SrcIPStr, DestIP = DstIPStr, DstPort, TotalMB, Connections, FirstSeen, LastSeen",
              "size": 0,
              "title": "Large Outbound Data Transfers (>100MB) - Potential Exfiltration",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "TotalMB",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
                    "columnMatch": "Connections",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "hunting-lateral-movement",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let LateralPorts = dynamic([\"22\", \"23\", \"135\", \"139\", \"445\", \"3389\", \"5985\", \"5986\"]);\nNetFlow_CL\n| extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n| where (SrcIPStr startswith \"192.168.\" or SrcIPStr startswith \"10.\") and (DstIPStr startswith \"192.168.\" or DstIPStr startswith \"10.\")\n| where tostring(DstPort) in (LateralPorts)\n| summarize Connections = count(), UniqueDests = dcount(DstIPStr), Ports = make_set(DstPort) by SrcIPStr\n| where UniqueDests >= 3\n| sort by UniqueDests desc\n| take 50\n| project SourceIP = SrcIPStr, UniqueTargets = UniqueDests, Connections, TargetPorts = Ports",
              "size": 0,
              "title": "Potential Lateral Movement (Internal Scanning on Admin Ports)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "UniqueTargets",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redBright"
                    }
                  },
                  {
                    "columnMatch": "Connections",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "orange"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "50"
          }
        ]
      }
    },
    {
      "type": 12,
      "name": "group-worldmap",
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "WorldMap"
      },
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Global Threat Heat Map\n\n**Geographic visualization of external threat sources correlated across all Sentinel & XDR data sources — NetFlow, Zeek/Corelight, Syslog firewalls, CEF, Cribl, Azure Firewall, Defender XDR, Threat Intel, and Security Alerts. Heat is log-scaled so mid-tier countries remain visible alongside high-volume regions.**",
              "style": "info"
            },
            "name": "text-worldmap-header"
          },
          {
            "type": 3,
            "name": "worldmap-combined",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let Events = union isfuzzy=true\n  (NetFlow_CL\n    | extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | extend SourceType = \"NetFlow\", Weight = 1.0),\n  (Syslog\n    | where Facility == \"kern\"\n    | extend ExternalIP = extract(@\"SRC=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | extend SourceType = \"Firewall-Syslog\", Weight = 3.0),\n  (CommonSecurityLog\n    | extend SrcIPStr = tostring(SourceIP), DstIPStr = tostring(DestinationIP)\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | extend SourceType = \"CEF\", Weight = 2.5),\n  (Zeek_CL\n    | extend SrcIPStr = tostring(column_ifexists(\"id_orig_h_s\", \"\")), DstIPStr = tostring(column_ifexists(\"id_resp_h_s\", \"\"))\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | extend SourceType = \"Zeek\", Weight = 2.0),\n  (Corelight_CL\n    | extend SrcIPStr = tostring(column_ifexists(\"src_ip_s\", \"\")), DstIPStr = tostring(column_ifexists(\"dst_ip_s\", \"\"))\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | extend SourceType = \"Corelight\", Weight = 2.0),\n  (Cribl_CL\n    | extend SrcIPStr = tostring(column_ifexists(\"src_ip_s\", column_ifexists(\"source_ip_s\", column_ifexists(\"srcip_s\", \"\"))))\n    | extend DstIPStr = tostring(column_ifexists(\"dst_ip_s\", column_ifexists(\"destination_ip_s\", column_ifexists(\"dstip_s\", \"\"))))\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | extend SourceType = \"Cribl\", Weight = 1.5),\n  (DeviceNetworkEvents\n    | extend ExternalIP = tostring(RemoteIP)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | extend SourceType = \"XDR-MDE\", Weight = 2.5),\n  (SecurityAlert\n    | extend entities = parse_json(Entities)\n    | mv-expand entity = entities\n    | extend ExternalIP = tostring(entity.Address)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | extend SourceType = \"SecurityAlert\", Weight = 5.0),\n  (ThreatIntelligenceIndicator\n    | extend ExternalIP = tostring(NetworkIP)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | extend SourceType = \"ThreatIntel\", Weight = 4.0),\n  (AzureDiagnostics\n    | where Category in (\"AzureFirewallNetworkRule\", \"AzureFirewallApplicationRule\")\n    | extend ExternalIP = extract(@\"(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, tostring(msg_s))\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | extend SourceType = \"AzureFirewall\", Weight = 2.5);\nEvents\n| extend Country = tostring(geo_info_from_ip_address(ExternalIP).country)\n| where isnotempty(Country) and Country != \"\"\n| summarize \n    TotalActivity = count(),\n    RawScore = sum(Weight),\n    UniqueIPs = dcount(ExternalIP),\n    Sources = make_set(SourceType)\n    by Country\n| extend SourceCount = array_length(Sources)\n| extend HeatScore = round(log10(RawScore + 1) * 10, 2)\n| extend SizeScore = round(log10(TotalActivity + 1) * 10, 2)\n| extend ActivityLabel = case(TotalActivity >= 1000000, strcat(tostring(round(todouble(TotalActivity)/1000000, 2)), \"M\"), TotalActivity >= 1000, strcat(tostring(round(todouble(TotalActivity)/1000, 1)), \"K\"), tostring(TotalActivity))\n| project Country, TotalActivity, ActivityLabel, HeatScore, SizeScore, RawScore, UniqueIPs, SourceCount, Sources\n| sort by TotalActivity desc",
              "size": 3,
              "title": "Global Threat Distribution by Country (All Sources, Log-Scaled Heat)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "map",
              "mapSettings": {
                "locInfo": "CountryRegion",
                "locInfoColumn": "Country",
                "sizeSettings": "SizeScore",
                "sizeAggregation": "Sum",
                "minSize": 10,
                "maxSize": 60,
                "opacity": 0.85,
                "defaultZoom": 1,
                "autoZoom": false,
                "centerLat": 20,
                "centerLong": 0,
                "labelSettings": "Country",
                "legendMetric": "TotalActivity",
                "legendAggregation": "Sum",
                "numberFormatSettings": {
                  "unit": 0,
                  "options": {
                    "style": "decimal",
                    "useGrouping": true,
                    "maximumFractionDigits": 2,
                    "maximumSignificantDigits": 4
                  }
                },
                "itemColorSettings": {
                  "nodeColorField": "HeatScore",
                  "colorAggregation": "Sum",
                  "type": "heatmap",
                  "heatmapPalette": "yellowOrangeRed"
                }
              },
              "chartSettings": {
                "showMetrics": true,
                "showLegend": true,
                "ySettings": {
                  "min": 0
                }
              }
            },
            "customWidth": "100",
            "customHeight": "900"
          },
          {
            "type": 3,
            "name": "worldmap-detail-grid",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let Events = union isfuzzy=true\n  (NetFlow_CL\n    | extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | extend InternalIP = iff(ipv4_is_private(SrcIPStr), SrcIPStr, iff(ipv4_is_private(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | project TimeGenerated, ExternalIP, InternalIP, SourceType=\"NetFlow\", DeviceName=tostring(column_ifexists(\"Computer\", \"\")), DstPort=tolong(column_ifexists(\"DstPort\", 0)), Protocol=tostring(column_ifexists(\"Protocol\", \"\")), Bytes=tolong(column_ifexists(\"Bytes\", 0)), Action=\"\"),\n  (Syslog\n    | where Facility == \"kern\"\n    | extend ExternalIP = extract(@\"SRC=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n    | extend InternalIPx = extract(@\"DST=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n    | extend DstPortx = tolong(extract(@\"DPT=(\\d+)\", 1, SyslogMessage))\n    | extend Protox = extract(@\"PROTO=([A-Z]+)\", 1, SyslogMessage)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | project TimeGenerated, ExternalIP, InternalIP=InternalIPx, SourceType=\"Firewall-Syslog\", DeviceName=tostring(Computer), DstPort=DstPortx, Protocol=Protox, Bytes=tolong(0), Action=\"block\"),\n  (CommonSecurityLog\n    | extend SrcIPStr = tostring(SourceIP), DstIPStr = tostring(DestinationIP)\n    | extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n    | extend InternalIPx = iff(ipv4_is_private(SrcIPStr), SrcIPStr, iff(ipv4_is_private(DstIPStr), DstIPStr, \"\"))\n    | where isnotempty(ExternalIP)\n    | project TimeGenerated, ExternalIP, InternalIP=InternalIPx, SourceType=\"CEF\", DeviceName=tostring(DeviceName), DstPort=tolong(DestinationPort), Protocol=tostring(Protocol), Bytes=tolong(column_ifexists(\"ReceivedBytes\", 0)), Action=tostring(DeviceAction)),\n  (DeviceNetworkEvents\n    | extend ExternalIP = tostring(RemoteIP)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | project TimeGenerated, ExternalIP, InternalIP=tostring(LocalIP), SourceType=\"XDR-MDE\", DeviceName=tostring(DeviceName), DstPort=tolong(RemotePort), Protocol=tostring(Protocol), Bytes=tolong(0), Action=tostring(ActionType)),\n  (SecurityAlert\n    | extend entities = parse_json(Entities)\n    | mv-expand entity = entities\n    | extend ExternalIP = tostring(entity.Address)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | project TimeGenerated, ExternalIP, InternalIP=\"\", SourceType=\"SecurityAlert\", DeviceName=tostring(CompromisedEntity), DstPort=tolong(0), Protocol=\"\", Bytes=tolong(0), Action=tostring(Status)),\n  (ThreatIntelligenceIndicator\n    | extend ExternalIP = tostring(NetworkIP)\n    | where isnotempty(ExternalIP) and not(ipv4_is_private(ExternalIP))\n    | project TimeGenerated, ExternalIP, InternalIP=\"\", SourceType=\"ThreatIntel\", DeviceName=\"\", DstPort=tolong(0), Protocol=\"\", Bytes=tolong(0), Action=tostring(ThreatType));\nEvents\n| extend Country = tostring(geo_info_from_ip_address(ExternalIP).country)\n| extend City = tostring(geo_info_from_ip_address(ExternalIP).city)\n| extend ASN = tostring(geo_info_from_ip_address(ExternalIP).state)\n| where isnotempty(Country) and Country != \"\"\n| where Country !in (\"United States\", \"United States of America\", \"USA\", \"US\")\n| summarize \n    Events = count(),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated),\n    Devices = make_set_if(DeviceName, isnotempty(DeviceName), 5),\n    InternalPeers = make_set_if(InternalIP, isnotempty(InternalIP), 5),\n    TopPorts = make_set_if(DstPort, DstPort > 0, 8),\n    Protocols = make_set_if(Protocol, isnotempty(Protocol), 5),\n    Actions = make_set_if(Action, isnotempty(Action), 5),\n    Sources = make_set(SourceType),\n    TotalBytes = sum(Bytes)\n    by IP=ExternalIP, Country, City\n| extend TIMatch = iff(Sources has \"ThreatIntel\", \"\\u26A0\\uFE0F Yes\", \"No\")\n| extend SourceCount = array_length(Sources)\n| extend DeviceCount = array_length(Devices)\n| extend PeerCount = array_length(InternalPeers)\n| project IP, Country, City, TIMatch, Events, FirstSeen, LastSeen, Devices, DeviceCount, InternalPeers, PeerCount, TopPorts, Protocols, Actions, TotalBytes, SourceCount, Sources\n| sort by Events desc\n| take 1000",
              "size": 0,
              "title": "Top 1000 External Threat IPs — Threat Hunter View (Non-US)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "TIMatch",
                    "formatter": 11
                  },
                  {
                    "columnMatch": "Events",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
                    "columnMatch": "FirstSeen",
                    "formatter": 6,
                    "dateFormat": {
                      "showUtcTime": false,
                      "formatName": "shortDateTimePattern"
                    }
                  },
                  {
                    "columnMatch": "LastSeen",
                    "formatter": 6,
                    "dateFormat": {
                      "showUtcTime": false,
                      "formatName": "shortDateTimePattern"
                    }
                  },
                  {
                    "columnMatch": "DeviceCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "orange"
                    }
                  },
                  {
                    "columnMatch": "PeerCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "TotalBytes",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "purple"
                    },
                    "numberFormat": {
                      "unit": 2,
                      "options": {
                        "style": "decimal",
                        "maximumFractionDigits": 2
                      }
                    }
                  },
                  {
                    "columnMatch": "SourceCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "green"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          }
        ]
      }
    },
    {
      "type": 12,
      "name": "group-investigate",
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Investigate"
      },
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Investigation Portal\n\n**Deep-dive investigation across all data sources for specific IPs, domains, or MAC addresses**\n\n**Current Search:** IP=`{SearchIP:value}` | Domain=`{SearchDomain:value}` | MAC=`{SearchMAC:value}`\n\nAll panels honor the TimeRange picker and the Search parameters above. Leave a field blank to match everything. Sources: NetFlow_CL, PiholeDNS_CL (dnsmasq raw log), Syslog (IPfreely/Switch firewall), ZeekLogs_CL (conn/dns/http), ThreatIntelligenceIndicator, DeviceInfo/DeviceNetworkInfo/DeviceNetworkEvents (MDE).",
              "style": "info"
            },
            "name": "text-investigate-header"
          },
          {
            "type": 3,
            "name": "investigate-timeline",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchDomain = tolower(\"{SearchDomain}\");\nlet searchMAC = tolower(\"{SearchMAC}\");\nunion isfuzzy=true\n    (NetFlow_CL\n        | where (isempty(searchIP)) or (SrcIP has searchIP or DstIP has searchIP)\n        | where (isempty(searchMAC)) or (tolower(SrcMac) has searchMAC or tolower(DstMac) has searchMAC)\n        | extend Source = \"NetFlow\"\n        | project TimeGenerated, Source),\n    (PiholeDNS_CL\n        | where logType_s == \"pihole-dns\" and isnotempty(_raw_s)\n        | extend Domain = tolower(coalesce(extract(@\"query\\[[\\w/]+\\]\\s+(\\S+)\\s+from\", 1, _raw_s), extract(@\"(?:cached|cached-stale|forwarded|reply|gravity\\s+blocked)\\s+(\\S+)\\s+(?:is|to)\", 1, _raw_s)))\n        | extend ClientIP = extract(@\"\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, _raw_s)\n        | where (isempty(searchIP)) or (ClientIP has searchIP)\n        | where (isempty(searchDomain)) or (Domain contains searchDomain)\n        | extend Source = \"PiholeDNS\"\n        | project TimeGenerated, Source),\n    (ZeekLogs_CL\n        | where (isempty(searchIP)) or (src_ip_s has searchIP or dst_ip_s has searchIP)\n        | where (isempty(searchDomain)) or (tolower(coalesce(dns_query_s, \"\")) contains searchDomain)\n        | extend Source = \"Zeek\"\n        | project TimeGenerated, Source),\n    (Syslog\n        | where Computer in (\"IPfreely\", \"Switch\")\n        | where SyslogMessage has \"SRC=\" and SyslogMessage has \"DST=\"\n        | extend SrcIP = extract(@\"SRC=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n        | extend DstIP = extract(@\"DST=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n        | where (isempty(searchIP)) or (SrcIP has searchIP or DstIP has searchIP)\n        | extend Source = \"FirewallBlock\"\n        | project TimeGenerated, Source),\n    (DeviceNetworkEvents\n        | where (isempty(searchIP)) or (RemoteIP has searchIP or LocalIP has searchIP)\n        | where (isempty(searchDomain)) or (tolower(coalesce(RemoteUrl, \"\")) contains searchDomain)\n        | extend Source = \"MDE_Network\"\n        | project TimeGenerated, Source)\n| summarize Events = count() by bin(TimeGenerated, 15m), Source\n| sort by TimeGenerated asc",
              "size": 0,
              "title": "Unified Event Timeline (All Sources)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "timechart",
              "chartSettings": {
                "group": "Source",
                "createOtherGroup": 0
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-netflow",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchMAC = tolower(\"{SearchMAC}\");\nNetFlow_CL\n| where (isempty(searchIP)) or (SrcIP has searchIP or DstIP has searchIP)\n| where (isempty(searchMAC)) or (tolower(SrcMac) has searchMAC or tolower(DstMac) has searchMAC)\n| summarize \n    Connections = count(),\n    TotalBytes = sum(Bytes),\n    TotalPackets = sum(Packets),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated)\n    by SrcIP, SrcMac, DstIP, DstMac, DstPort, Protocol\n| extend TotalMB = round(TotalBytes / 1048576.0, 2)\n| sort by Connections desc\n| take 200\n| project SrcIP, SrcMAC = SrcMac, DstIP, DstMAC = DstMac, DstPort, Protocol, Connections, TotalMB, TotalPackets, FirstSeen, LastSeen",
              "size": 0,
              "title": "NetFlow Connections (Filtered by Search)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Connections",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "TotalMB",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "green"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-dns",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchDomain = tolower(\"{SearchDomain}\");\nPiholeDNS_CL\n| where logType_s == \"pihole-dns\" and isnotempty(_raw_s)\n| extend Action = extract(@\"dnsmasq\\[\\d+\\]:\\s+(\\S+)\", 1, _raw_s)\n| extend QueryType = extract(@\"query\\[([\\w/]+)\\]\", 1, _raw_s)\n| extend Domain = tolower(coalesce(extract(@\"query\\[[\\w/]+\\]\\s+(\\S+)\\s+from\", 1, _raw_s), extract(@\"(?:cached|cached-stale|forwarded|reply|gravity\\s+blocked|regex\\s+blacklisted|config)\\s+(\\S+)\\s+(?:is|to)\", 1, _raw_s)))\n| extend ClientIP = extract(@\"\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, _raw_s)\n| extend IsBlocked = Action has_any (\"gravity\", \"blacklist\", \"regex\")\n| where isnotempty(Domain) and Domain !in (\"<cname>\", \"<ptr>\", \"0.0.0.0\", \"::\")\n| where (isempty(searchIP)) or (ClientIP has searchIP)\n| where (isempty(searchDomain)) or (Domain contains searchDomain)\n| summarize \n    QueryCount = count(),\n    Blocked = countif(IsBlocked),\n    QueriesIssued = countif(Action startswith \"query\"),\n    Forwarded = countif(Action == \"forwarded\"),\n    Cached = countif(Action in (\"cached\", \"cached-stale\")),\n    FirstQuery = min(TimeGenerated),\n    LastQuery = max(TimeGenerated),\n    QueryTypes = make_set(QueryType, 10),\n    Actions = make_set(Action, 10)\n    by Domain, ClientIP\n| sort by QueryCount desc\n| take 200\n| project Domain, ClientIP, QueryCount, Blocked, QueriesIssued, Forwarded, Cached, QueryTypes, Actions, FirstQuery, LastQuery",
              "size": 0,
              "title": "DNS Queries (Filtered by Search)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "QueryCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "purple"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-firewall",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nSyslog\n| where Computer in (\"IPfreely\", \"Switch\")\n| where SyslogMessage has \"SRC=\" and SyslogMessage has \"DST=\"\n| extend SrcIP = extract(@\"SRC=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n| extend DstIP = extract(@\"DST=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n| extend SrcPort = extract(@\"SPT=(\\d+)\", 1, SyslogMessage)\n| extend DstPort = extract(@\"DPT=(\\d+)\", 1, SyslogMessage)\n| extend Proto = extract(@\"PROTO=(\\w+)\", 1, SyslogMessage)\n| extend RuleName = extract(@\"\\[([^\\]]+)\\]\", 1, SyslogMessage)\n| extend InIface = extract(@\"IN=(\\S+)\", 1, SyslogMessage)\n| extend OutIface = extract(@\"OUT=(\\S*)\", 1, SyslogMessage)\n| where isnotempty(SrcIP)\n| where (isempty(searchIP)) or (SrcIP has searchIP or DstIP has searchIP)\n| summarize \n    BlockCount = count(),\n    FirstBlocked = min(TimeGenerated),\n    LastBlocked = max(TimeGenerated),\n    Facilities = make_set(Facility, 5)\n    by Computer, SrcIP, DstIP, DstPort, Protocol = Proto, RuleName, InIface, OutIface\n| sort by BlockCount desc\n| take 200\n| project Computer, SrcIP, DstIP, DstPort, Protocol, RuleName, InIface, OutIface, Facilities, BlockCount, FirstBlocked, LastBlocked",
              "size": 0,
              "title": "Firewall Blocks (Filtered by Search)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "BlockCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-zeek",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchDomain = tolower(\"{SearchDomain}\");\nZeekLogs_CL\n| where (isempty(searchIP)) or (src_ip_s has searchIP or dst_ip_s has searchIP)\n| extend DomainLower = tolower(coalesce(dns_query_s, \"\"))\n| where (isempty(searchDomain)) or (DomainLower contains searchDomain)\n| extend DstPortInt = toint(dst_port_s)\n| summarize \n    EventCount = count(),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated),\n    DstPorts = make_set(DstPortInt, 20),\n    Protocols = make_set(proto_s, 5),\n    Domains = make_set(dns_query_s, 10)\n    by LogType = logType_s, SrcIP = src_ip_s, DstIP = dst_ip_s\n| sort by EventCount desc\n| take 200\n| project LogType, SrcIP, DstIP, Protocols, DstPorts, Domains, EventCount, FirstSeen, LastSeen",
              "size": 0,
              "title": "Zeek Events (Filtered by Search)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "EventCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "orange"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-threat-intel",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet ti = ThreatIntelligenceIndicator\n    | where TimeGenerated > ago(30d)\n    | extend ThreatIP = coalesce(NetworkIP, NetworkSourceIP, NetworkDestinationIP)\n    | where isnotempty(ThreatIP)\n    | where (isempty(searchIP)) or (ThreatIP has searchIP)\n    | summarize arg_max(TimeGenerated, *) by ThreatIP;\nlet nfHits = NetFlow_CL\n    | summarize NetFlowHits = count(), BytesSeen = sum(Bytes), LastHit = max(TimeGenerated) by ThreatIP = iff(DstIP in ((ti | project ThreatIP)), DstIP, SrcIP)\n    | where isnotempty(ThreatIP);\nti\n| join kind=leftouter nfHits on ThreatIP\n| project ThreatIP, ThreatType, Description, ConfidenceScore, Active, Tags, ExpirationDateTime, NetFlowHits = coalesce(NetFlowHits, 0), BytesSeen = coalesce(BytesSeen, 0), LastHit, Indicator = TimeGenerated\n| sort by NetFlowHits desc, ConfidenceScore desc\n| take 200",
              "size": 0,
              "title": "Threat Intelligence Matches (Filtered by Search)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ConfidenceScore",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-mde-correlation",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchMAC = tolower(\"{SearchMAC}\");\nlet NetworkIPs =\n    NetFlow_CL\n    | where (isempty(searchIP)) or (SrcIP has searchIP or DstIP has searchIP)\n    | where (isempty(searchMAC)) or (tolower(SrcMac) has searchMAC or tolower(DstMac) has searchMAC)\n    | project TimeGenerated, Src = SrcIP, Dst = DstIP, SrcMac, DstMac, Bytes\n    | mv-expand pair = pack_array(pack(\"ip\", Src, \"mac\", SrcMac), pack(\"ip\", Dst, \"mac\", DstMac))\n    | extend IP = tostring(pair.ip), Mac = tolower(tostring(pair.mac))\n    | where isnotempty(IP)\n    | summarize NetFlowConnections = count(), TotalBytes = sum(Bytes), MacAddresses = make_set_if(Mac, isnotempty(Mac), 5) by IP;\nlet MDEDevices = union isfuzzy=true\n    (DeviceInfo\n        | where TimeGenerated > ago(7d)\n        | mv-expand IPAddresses\n        | extend IP = tostring(IPAddresses)\n        | where isnotempty(IP)\n        | summarize arg_max(TimeGenerated, *) by IP\n        | project IP, DeviceName, DeviceType, OSPlatform, OSVersion, MachineGroup, DeviceId, LastSeen = TimeGenerated),\n    (DeviceNetworkInfo\n        | where TimeGenerated > ago(7d)\n        | mv-expand IPAddresses\n        | extend IP = tostring(IPAddresses.IPAddress)\n        | extend MdeMac = tolower(replace_string(coalesce(MacAddress, \"\"), \"-\", \":\"))\n        | where isnotempty(IP)\n        | summarize arg_max(TimeGenerated, *) by IP\n        | project IP, DeviceName, MdeMac, NetworkAdapterStatus, DeviceId, LastSeen = TimeGenerated),\n    (datatable(IP:string, DeviceName:string, DeviceType:string, OSPlatform:string, OSVersion:string, MachineGroup:string, MdeMac:string, NetworkAdapterStatus:string, DeviceId:string, LastSeen:datetime)[])\n    | summarize arg_max(LastSeen, *) by IP;\nNetworkIPs\n| join kind=leftouter MDEDevices on IP\n| extend TotalMB = round(TotalBytes / 1048576.0, 2)\n| project IP, DeviceName, DeviceType, OSPlatform, OSVersion, MdeMac, MacAddresses, MachineGroup, NetFlowConnections, TotalMB, LastSeen, DeviceId, NetworkAdapterStatus\n| sort by NetFlowConnections desc\n| take 200",
              "size": 0,
              "title": "MDE Device Correlation: IP Addresses with Device Names and MACs",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "DeviceName",
                    "formatter": 5,
                    "formatOptions": {
                      "customColumnWidthSetting": "20%"
                    }
                  },
                  {
                    "columnMatch": "NetFlowConnections",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "TotalMB",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "green"
                    }
                  },
                  {
                    "columnMatch": "DeviceId",
                    "formatter": 5
                  }
                ],
                "filter": true,
                "sortBy": [
                  {
                    "itemKey": "$gen_heatmap_NetFlowConnections_7",
                    "sortOrder": 2
                  }
                ],
                "labelSettings": [
                  {
                    "columnId": "IP",
                    "label": "IP Address"
                  },
                  {
                    "columnId": "DeviceName",
                    "label": "Device Name (MDE)"
                  },
                  {
                    "columnId": "MacAddress",
                    "label": "MAC Address"
                  }
                ],
                "rowLimit": 10000
              },
              "sortBy": [
                {
                  "itemKey": "$gen_heatmap_NetFlowConnections_7",
                  "sortOrder": 2
                }
              ]
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "investigate-mde-network-events",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let searchIP = \"{SearchIP}\";\nlet searchDomain = tolower(\"{SearchDomain}\");\nDeviceNetworkEvents\n| where (isempty(searchIP)) or (RemoteIP has searchIP or LocalIP has searchIP)\n| where (isempty(searchDomain)) or (tolower(coalesce(RemoteUrl, \"\")) contains searchDomain)\n| summarize \n    Events = count(),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated),\n    Actions = make_set(ActionType, 10),\n    Urls = make_set(RemoteUrl, 10),\n    LocalPorts = make_set(LocalPort, 10),\n    RemotePorts = make_set(RemotePort, 10),\n    Protocols = make_set(Protocol, 5)\n    by DeviceName, InitiatingProcessFileName, InitiatingProcessAccountName, RemoteIP, LocalIP\n| sort by Events desc\n| take 200\n| project DeviceName, InitiatingProcessFileName, InitiatingProcessAccountName, RemoteIP, LocalIP, RemotePorts, LocalPorts, Protocols, Actions, Urls, Events, FirstSeen, LastSeen",
              "size": 0,
              "title": "MDE DeviceNetworkEvents (Process-level Connection Correlation)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Events",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "Actions",
                    "formatter": 1
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          }
        ]
      }
    }
  ],
  "fallbackResourceIds": [
    "/subscriptions/SUBSCRIPTION_ID/resourceGroups/RESOURCE_GROUP/providers/Microsoft.OperationalInsights/workspaces/WORKSPACE_NAME"
  ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
