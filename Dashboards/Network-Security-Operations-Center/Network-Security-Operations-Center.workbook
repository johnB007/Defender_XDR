                ],
                "filter": true
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "zeek-ssl-activity",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Top SSL/TLS connections from Zeek - SOC enriched (DeviceName, MAC, SSID, IP, Vendor)\nlet MdeAny = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),'-',''),':',''))\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| where isnotempty(IPAddr) and IPAddr matches regex @'^(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)'\n| extend MdeSsid = tostring(parse_json(tostring(ConnectedNetworks))[0].Name)\n| summarize arg_max(TimeGenerated, DeviceName, DeviceId, MACNorm, NetworkAdapterVendor, MdeSsid) by IP=IPAddr\n| project IP, MdeDeviceName=DeviceName, DeviceId, MACNorm, NicVendor=NetworkAdapterVendor, MdeSsid;\nlet DevInfo = DeviceInfo\n| where TimeGenerated > ago(30d)\n| summarize arg_max(Timestamp, Vendor, OnboardingStatus) by DeviceId\n| project DeviceId, DevVendor=Vendor, OnboardingStatus;\nlet ZeekDhcp = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == 'dhcp'\n| extend f = split(_raw_s, '\\t')\n| extend IP = tostring(f[9]), MAC = tostring(f[4]), HostName = tostring(f[5])\n| where isnotempty(IP) and IP != '-'\n| extend MACNorm = tolower(replace_string(MAC,':',''))\n| summarize arg_max(TimeGenerated, MACNorm, HostName) by IP\n| project IP, DhcpMAC=MACNorm, DhcpHost=HostName;\nZeekLogs_CL\n| where logType_s == 'ssl'\n| extend f = split(_raw_s, '\\t')\n| extend ServerName = tostring(f[9]), Version = tostring(f[6]), SrcIP = coalesce(tostring(src_ip_s), tostring(f[2]))\n| where isnotempty(ServerName) and ServerName != '-' and isnotempty(SrcIP)\n| summarize ConnectionCount=count(), UniqueClients=dcount(SrcIP), ClientIPs=make_set(SrcIP, 25) by ServerName, Version\n| top 100 by ConnectionCount\n| mv-expand ClientIP = ClientIPs to typeof(string)\n| join kind=leftouter MdeAny on $left.ClientIP == $right.IP\n| join kind=leftouter DevInfo on DeviceId\n| join kind=leftouter ZeekDhcp on $left.ClientIP == $right.IP\n| extend MACNorm = coalesce(MACNorm, DhcpMAC, '')\n| extend MACFmt = iff(strlen(MACNorm) == 12, strcat(substring(MACNorm,0,2),':',substring(MACNorm,2,2),':',substring(MACNorm,4,2),':',substring(MACNorm,6,2),':',substring(MACNorm,8,2),':',substring(MACNorm,10,2)), '')\n| extend EffDevice = coalesce(MdeDeviceName, DhcpHost, '')\n| extend EffVendor = coalesce(DevVendor, NicVendor, '')\n| extend EffSSID  = coalesce(MdeSsid, '')\n| extend Source = case(\n    OnboardingStatus == 'Onboarded', 'Managed (MDE)',\n    isnotempty(MdeDeviceName), 'Seen by MDE',\n    isnotempty(DhcpHost), 'DHCP only',\n    'Unmanaged')\n| summarize ConnectionCount=any(ConnectionCount), UniqueClients=any(UniqueClients),\n    DeviceNames = make_set_if(EffDevice, isnotempty(EffDevice), 10),\n    MACs        = make_set_if(MACFmt, isnotempty(MACFmt), 10),\n    Vendors     = make_set_if(EffVendor, isnotempty(EffVendor), 10),\n    SSIDs       = make_set_if(EffSSID, isnotempty(EffSSID), 10),\n    Sources     = make_set_if(Source, isnotempty(Source), 5),\n    ClientIPs   = make_set(ClientIP, 25)\n    by ServerName, Version\n| project ServerName, Version, ConnectionCount, UniqueClients, DeviceNames, MACs, Vendors, SSIDs, Sources, ClientIPs\n| sort by ConnectionCount desc",
              "size": 0,
              "title": "Top SSL/TLS Connections from Zeek (Identity Enriched)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ConnectionCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "green"
                    },
                    "columnWidth": "70px"
                  },
                  {
                    "columnMatch": "UniqueClients",
                    "formatter": 8,
