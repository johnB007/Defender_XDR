          {
            "type": 3,
            "name": "zeek-notices-alerts",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Zeek Notices / Weird / Intel - SOC enriched on both Src and Dst sides\nlet ident = union\n  (DeviceNetworkInfo | where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n    | extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),'-',''),':',''))\n    | mv-expand ip = parse_json(IPAddresses)\n    | extend IP = tostring(ip.IPAddress)\n    | where isnotempty(IP)\n    | extend SSID = tostring(parse_json(tostring(ConnectedNetworks))[0].Name)\n    | summarize arg_max(TimeGenerated, DeviceName, DeviceId, MACNorm, SSID, NetworkAdapterVendor) by IP\n    | project IP, DeviceName, DeviceId, MACNorm, SSID, Vendor=NetworkAdapterVendor, Source='Managed (MDE)', Fidelity=1),\n  (Heartbeat | where TimeGenerated > ago(7d) and isnotempty(ComputerIP)\n    | summarize arg_max(TimeGenerated, Computer) by ComputerIP\n    | project IP=ComputerIP, DeviceName=Computer, DeviceId='', MACNorm='', SSID='', Vendor='', Source='Managed (Arc)', Fidelity=2),\n  (ZeekLogs_CL | where TimeGenerated > ago(30d) and logType_s == 'dhcp'\n    | extend f = split(_raw_s, '\\t')\n    | extend IP = tostring(f[9]), MAC = tostring(f[4]), HostName = tostring(f[5])\n    | where isnotempty(IP) and IP != '-'\n    | extend MACNorm = tolower(replace_string(MAC,':',''))\n    | summarize arg_max(TimeGenerated, MACNorm, HostName) by IP\n    | project IP, DeviceName=iff(isempty(HostName) or HostName=='-', strcat('dhcp-', substring(MACNorm, 6, 6)), HostName), DeviceId='', MACNorm, SSID='', Vendor='', Source='DHCP (Zeek)', Fidelity=3)\n| summarize arg_min(Fidelity, DeviceName, DeviceId, MACNorm, SSID, Vendor, Source) by IP;\nlet devInfoVendor = DeviceInfo | where TimeGenerated > ago(30d) | summarize arg_max(Timestamp, Vendor) by DeviceId | project DeviceId, DevVendor=Vendor;\nZeekLogs_CL\n| where logType_s in ('notice', 'intel', 'weird')\n| extend fields = split(_raw_s, '\\t')\n| extend Note = tostring(fields[10]), Msg = tostring(fields[11]),\n         SrcIP = coalesce(tostring(src_ip_s), tostring(fields[2])),\n         DstIP = coalesce(tostring(dst_ip_s), tostring(fields[4]))\n| extend Note = iff(isnotempty(Msg) and Msg != '-', strcat(Note, ': ', Msg), Note)\n| where isnotempty(Note) and Note != '-'\n| summarize AlertCount = count(), FirstSeen = min(TimeGenerated), LastSeen = max(TimeGenerated) by Note, SrcIP, DstIP\n| sort by AlertCount desc\n| take 100\n| join kind=leftouter (ident | project SrcIP=IP, SrcDevice=DeviceName, SrcDeviceId=DeviceId, SrcMACNorm=MACNorm, SrcSSID=SSID, SrcNicVendor=Vendor, SrcSource=Source) on SrcIP\n| join kind=leftouter (ident | project DstIP=IP, DstDevice=DeviceName, DstDeviceId=DeviceId, DstMACNorm=MACNorm, DstSSID=SSID, DstNicVendor=Vendor, DstSource=Source) on DstIP\n| join kind=leftouter (devInfoVendor | project SrcDeviceId=DeviceId, SrcDevVendor=DevVendor) on SrcDeviceId\n| join kind=leftouter (devInfoVendor | project DstDeviceId=DeviceId, DstDevVendor=DevVendor) on DstDeviceId\n| extend SrcMAC = iff(strlen(SrcMACNorm) == 12, strcat(substring(SrcMACNorm,0,2),':',substring(SrcMACNorm,2,2),':',substring(SrcMACNorm,4,2),':',substring(SrcMACNorm,6,2),':',substring(SrcMACNorm,8,2),':',substring(SrcMACNorm,10,2)), '')\n| extend DstMAC = iff(strlen(DstMACNorm) == 12, strcat(substring(DstMACNorm,0,2),':',substring(DstMACNorm,2,2),':',substring(DstMACNorm,4,2),':',substring(DstMACNorm,6,2),':',substring(DstMACNorm,8,2),':',substring(DstMACNorm,10,2)), '')\n| extend SrcVendor = coalesce(SrcDevVendor, SrcNicVendor, '')\n| extend DstVendor = coalesce(DstDevVendor, DstNicVendor, '')\n| extend Coverage = coalesce(SrcSource, 'Unknown / Not Onboarded')\n| project Note, SrcIP, SrcDevice, SrcMAC, SrcSSID, SrcVendor, Coverage, DstIP, DstDevice, DstMAC, DstVendor, AlertCount, FirstSeen, LastSeen",
              "size": 0,
              "title": "Zeek Notices & Alerts (Identity Enriched)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "AlertCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
                    "columnMatch": "Note",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "orange",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "Coverage",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Managed (MDE)",
                          "representation": "green",
                          "text": "Managed (MDE)"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Managed (Arc)",
                          "representation": "blue",
                          "text": "Managed (Arc)"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "DHCP (Zeek)",
                          "representation": "yellow",
                          "text": "DHCP (Zeek)"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Unknown / Not Onboarded",
                          "representation": "redBright",
                          "text": "Unknown / Not Onboarded"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "unified-domain-search",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let s = tolower(\"{SearchDomain}\");\nunion isfuzzy=true\n  (PiholeDNS_CL\n    | extend Domain = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|cached-stale|forwarded|reply|gravity\\s+blocked|regex\\s+blacklisted|config)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s)))\n    | extend ClientIP = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s)\n    | where isnotempty(Domain) and Domain !in ('<cname>','<ptr>','0.0.0.0','::')\n    | where isempty(s) or Domain has s\n    | project TimeGenerated, Source = 'DNS Sinkhole', Domain, ClientIP),\n  (ZeekLogs_CL\n    | where logType_s == 'dns' and isnotempty(dns_query_s) and dns_query_s != '-'\n    | where isempty(s) or tolower(dns_query_s) has s\n    | project TimeGenerated, Source = 'Zeek DNS', Domain = tolower(dns_query_s), ClientIP = tostring(src_ip_s)),\n  (ZeekLogs_CL\n    | where logType_s == 'ssl'\n    | extend f = split(_raw_s, '\\t')\n    | extend Domain = tolower(tostring(f[9]))\n    | where isnotempty(Domain) and Domain != '-'\n    | where isempty(s) or Domain has s\n    | project TimeGenerated, Source = 'Zeek SSL/SNI', Domain, ClientIP = tostring(src_ip_s)),\n  (ZeekLogs_CL\n    | where logType_s == 'http'\n    | extend f = split(_raw_s, '\\t')\n    | extend Domain = tolower(tostring(f[8]))\n    | where isnotempty(Domain) and Domain != '-'\n    | where isempty(s) or Domain has s\n    | project TimeGenerated, Source = 'Zeek HTTP', Domain, ClientIP = tostring(src_ip_s)),\n  (ZeekLogs_CL\n    | where logType_s == 'socks'\n    | extend f = split(_raw_s, '\\t')\n    | extend Domain = tolower(tostring(f[11]))\n    | where isnotempty(Domain) and Domain != '-'\n    | where isempty(s) or Domain has s\n    | project TimeGenerated, Source = 'Zeek SOCKS', Domain, ClientIP = tostring(src_ip_s)),\n  (DeviceNetworkEvents\n    | where isnotempty(RemoteUrl)\n    | where isempty(s) or tolower(RemoteUrl) has s\n    | project TimeGenerated, Source = 'MDE Network', Domain = tolower(RemoteUrl), ClientIP = tostring(LocalIP))\n| summarize Hits = count(), UniqueClients = dcount(ClientIP), Clients = make_set(ClientIP, 10), FirstSeen = min(TimeGenerated), LastSeen = max(TimeGenerated) by Source, Domain\n| top 500 by Hits",
              "size": 0,
              "title": "Unified Domain Search - All Sources (DNS Sinkhole + Zeek DNS/SSL/HTTP/SOCKS + MDE)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Hits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
                    "columnMatch": "UniqueClients",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "Source",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "DNS Sinkhole",
                          "representation": "blue",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Zeek DNS",
                          "representation": "green",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Zeek SSL/SNI",
                          "representation": "purple",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Zeek HTTP",
                          "representation": "turquoise",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Zeek SOCKS",
                          "representation": "orange",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "MDE Network",
                          "representation": "redBright",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  }
                ],
                "filter": true,
                "rowLimit": 10000
              }
            },
            "customWidth": "100"
          }
        ]
      }
    },
    {
      "type": 12,
      "name": "group-correlation",
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Correlation"
      },
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Threat Correlation\n\n**Cross-source threat correlation: IPs, domains, URLs, and file hashes from MDTI + abuse.ch (URLhaus, ThreatFox, Feodo Tracker, MalwareBazaar, SSLBL) in `ThreatIntelIndicators`, matched against NetFlow, Zeek, Firewall, DNS, and MDE. The `TI_Source` / `Tags` columns identify which feed flagged the IOC.**",
              "style": "info"
            },
            "name": "text-correlation-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TI = ThreatIntelIndicators | where TimeGenerated > ago(24h) and IsActive == true;\nlet TIip = TI | where ObservableKey in (\"network-traffic:src_ref.value\",\"network-traffic:dst_ref.value\",\"ipv4-addr:value\") | distinct ObservableValue;\nlet TIdom = TI | where ObservableKey == \"domain-name:value\" | distinct tolower(ObservableValue);\nlet ipHits = union\n  (NetFlow_CL | where TimeGenerated > ago(24h) | extend Ip = case(not(ipv4_is_private(SrcIP)), SrcIP, DstIP) | where Ip in (TIip)),\n  (ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"conn\" | extend Ip = case(not(ipv4_is_private(src_ip_s)), src_ip_s, dst_ip_s) | where Ip in (TIip)),\n  (DeviceNetworkEvents | where TimeGenerated > ago(24h) | where RemoteIP in (TIip) | project Ip = RemoteIP)\n  | distinct Ip;\nlet domHits = union\n  (ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"dns\" | extend d = tolower(dns_query_s) | where d in (TIdom) | project d),\n  (PiholeDNS_CL | where TimeGenerated > ago(24h) | extend d = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|forwarded|reply)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s))) | where d in (TIdom) | project d)\n  | distinct d;\nlet nonMdeDev = union\n  (ZeekLogs_CL | where TimeGenerated > ago(24h) and logType_s == \"conn\" | extend Ext = case(not(ipv4_is_private(dst_ip_s)), dst_ip_s, src_ip_s), Int = case(ipv4_is_private(src_ip_s), src_ip_s, dst_ip_s) | where Ext in (TIip) | project Int),\n  (PiholeDNS_CL | where TimeGenerated > ago(24h) | extend d = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|forwarded|reply)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s))), Int = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s) | where d in (TIdom) | project Int)\n  | where isnotempty(Int) | distinct Int;\nunion\n  (print Column = \"Active TI Indicators (24h)\", Value = toscalar(TI | count)),\n  (print Column = \"TI IP Hits (24h)\", Value = toscalar(ipHits | count)),\n  (print Column = \"TI Domain Hits (24h)\", Value = toscalar(domHits | count)),\n  (print Column = \"Non-MDE Devices Touching TI (24h)\", Value = toscalar(nonMdeDev | count))",
              "size": 3,
              "title": "Threat Correlation KPIs (24h)",
              "noDataMessage": "No TI activity in the last 24h",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Column",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Value",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "auto"
                  }
                },
                "showBorder": true
              },
              "tileSettings_unused": "see chartSettings",
              "chartSettings": {
                "showDataPoints": true
              }
            },
            "name": "correlation-kpi-tiles"
          },
          {
            "type": 3,
            "name": "correlation-cross-source-ips",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIIPs = ThreatIntelIndicators\n| where TimeGenerated > ago(30d) and IsActive == true\n| where ObservableKey in (\"network-traffic:src_ref.value\",\"network-traffic:dst_ref.value\",\"ipv4-addr:value\")\n| summarize arg_max(TimeGenerated, Confidence, Tags, Pattern, ValidUntil, Id, SourceSystem) by ObservableValue\n| project IP = ObservableValue, TI_Confidence = toint(Confidence), TI_Tags = tostring(Tags), TI_Pattern = tostring(Pattern), TI_ValidUntil = ValidUntil, TI_IndicatorId = tostring(Id), TI_Source = tostring(SourceSystem);\nlet AlertIPs = SecurityAlert\n| where TimeGenerated > ago(30d)\n| extend ents = parse_json(Entities)\n| mv-expand ent = ents\n| where tostring(ent.Type) == \"ip\"\n| extend IP = tostring(ent.Address)\n| where isnotempty(IP) and not(ipv4_is_private(IP))\n| summarize arg_max(TimeGenerated, AlertName, AlertSeverity, Description) by IP\n| project IP, TI_Confidence = toint(case(AlertSeverity == \"High\", 90, AlertSeverity == \"Medium\", 70, 50)), TI_Tags = tostring(AlertName), TI_Pattern = tostring(Description), TI_ValidUntil = TimeGenerated, TI_IndicatorId = \"\", TI_Source = \"SecurityAlert\";\nlet TI = union TIIPs, AlertIPs\n| summarize arg_max(TI_Confidence, TI_Source, TI_Tags, TI_Pattern, TI_ValidUntil, TI_IndicatorId) by IP;\nlet NetFlowIPs = NetFlow_CL\n| extend SrcIPStr = tostring(SrcIP), DstIPStr = tostring(DstIP)\n| extend ExternalIP = iff(not(ipv4_is_private(SrcIPStr)) and isnotempty(SrcIPStr), SrcIPStr, iff(not(ipv4_is_private(DstIPStr)) and isnotempty(DstIPStr), DstIPStr, \"\"))\n| where isnotempty(ExternalIP)\n| summarize NetFlowHits = count() by IP = ExternalIP;\nlet FirewallIPs = Syslog\n| where Facility == \"kern\"\n| extend SrcIP = extract(@\"SRC=(\\d+\\.\\d+\\.\\d+\\.\\d+)\", 1, SyslogMessage)\n| where isnotempty(SrcIP) and not(ipv4_is_private(SrcIP))\n| summarize FirewallBlocks = count() by IP = SrcIP;\nlet ZeekIPs = ZeekLogs_CL\n| extend s = tostring(src_ip_s), d = tostring(dst_ip_s)\n| extend ExternalIP = iff(not(ipv4_is_private(s)) and isnotempty(s) and s != \"-\", s, iff(not(ipv4_is_private(d)) and isnotempty(d) and d != \"-\", d, \"\"))\n| where isnotempty(ExternalIP)\n| summarize ZeekHits = count() by IP = ExternalIP;\nlet MdeIPs = DeviceNetworkEvents\n| extend IP = tostring(RemoteIP)\n| where isnotempty(IP) and not(ipv4_is_private(IP))\n| summarize MdeHits = count() by IP;\nNetFlowIPs\n| join kind=fullouter FirewallIPs on IP\n| join kind=fullouter ZeekIPs on IP\n| join kind=fullouter MdeIPs on IP\n| extend IP = coalesce(IP, IP1, IP2, IP3)\n| extend NetFlowHits = coalesce(NetFlowHits, 0), FirewallBlocks = coalesce(FirewallBlocks, 0), ZeekHits = coalesce(ZeekHits, 0), MdeHits = coalesce(MdeHits, 0)\n| project IP, NetFlowHits, FirewallBlocks, ZeekHits, MdeHits\n| join kind=leftouter TI on IP\n| project-away IP1\n| extend TI_Match = iff(isnotempty(TI_Confidence), \"Yes\", \"No\")\n| extend NonMdeHits = NetFlowHits + FirewallBlocks + ZeekHits\n| extend SourceCount = toint(NetFlowHits > 0) + toint(FirewallBlocks > 0) + toint(ZeekHits > 0) + toint(MdeHits > 0)\n| extend NonMdeOnly = iff(NonMdeHits > 0 and MdeHits == 0, \"Yes\", \"No\")\n| where SourceCount >= 2 or TI_Match == \"Yes\"\n| extend ThreatScore = (NetFlowHits * 0.5) + (FirewallBlocks * 3) + (ZeekHits * 2) + (MdeHits * 2) + iff(TI_Match == \"Yes\", 1000.0 + todouble(coalesce(TI_Confidence, 0)) * 10, 0.0)\n| extend TiPriority = iff(TI_Match == \"Yes\", 1, 0)\n| sort by TiPriority desc, ThreatScore desc\n| take 250\n| project IP, TI_Source, TI_Match, TI_Confidence, SourceCount, ThreatScore, NonMdeOnly, NonMdeHits, NetFlowHits, FirewallBlocks, ZeekHits, MdeHits, TI_Tags, TI_ValidUntil, TI_Pattern, TI_IndicatorId\n",
              "size": 0,
              "title": "Cross-Source IP Correlation — IPs in 2+ sources OR matched by TI/SecurityAlert (TI=30d, includes non-MDE devices)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ThreatScore",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "redBright"
                    }
                  },
                  {
                    "columnMatch": "SourceCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "orange"
                    }
                  },
                  {
                    "columnMatch": "TI_Match",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Yes",
                          "representation": "critical",
                          "text": "Yes"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "No"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "TI_Confidence",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red"
                    }
                  },
                  {
                    "columnMatch": "NonMdeOnly",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Yes",
                          "representation": "warning",
                          "text": "Yes"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "No"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "NonMdeHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "yellow"
                    }
                  },
                  {
                    "columnMatch": "NetFlowHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "ZeekHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "purple"
                    }
                  },
                  {
                    "columnMatch": "FirewallBlocks",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "orange"
                    }
                  },
                  {
                    "columnMatch": "MdeHits",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "coral"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "correlation-ti-ip-matches",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIIPs = ThreatIntelIndicators\n| where TimeGenerated > ago(30d) and IsActive == true\n| where ObservableKey in (\"network-traffic:src_ref.value\",\"network-traffic:dst_ref.value\",\"ipv4-addr:value\")\n| summarize arg_max(TimeGenerated, Confidence, Tags, Pattern, ValidUntil, Id, SourceSystem) by ObservableValue\n| project ThreatIP = ObservableValue, Confidence = toint(Confidence), TISource = tostring(SourceSystem), Tags = tostring(Tags), Pattern = tostring(Pattern), ValidUntil, IndicatorId = tostring(Id);\nlet AlertIPs = SecurityAlert\n| where TimeGenerated > ago(30d)\n| mv-expand todynamic(Entities)\n| where tostring(Entities.Type) == \"ip\"\n| extend ThreatIP = tostring(Entities.Address)\n| where ThreatIP matches regex @'^\\d+\\.\\d+\\.\\d+\\.\\d+$' and not(ipv4_is_private(ThreatIP))\n| summarize Confidence = toint(case(AlertSeverity==\"High\",90,AlertSeverity==\"Medium\",70,AlertSeverity==\"Low\",50,30)), TISource = \"SecurityAlert\", Tags = strcat_array(make_set(AlertName,5), \" | \"), Pattern = \"\", ValidUntil = max(TimeGenerated), IndicatorId = \"\" by ThreatIP;\nlet TI = union TIIPs, AlertIPs | summarize arg_max(Confidence, *) by ThreatIP;\nlet NetFlowHits = NetFlow_CL\n| extend SrcIp = tostring(SrcIP), DstIp = tostring(DstIP)\n| extend ThreatIP = case(not(ipv4_is_private(SrcIp)), SrcIp, not(ipv4_is_private(DstIp)), DstIp, \"\")\n| where isnotempty(ThreatIP)\n| extend InternalIP = case(ipv4_is_private(SrcIp), SrcIp, ipv4_is_private(DstIp), DstIp, \"\")\n| summarize NetFlowHits = count(), NetFlowClients = make_set(InternalIP, 10), LastNetFlow = max(TimeGenerated) by ThreatIP;\nlet ZeekConnHits = ZeekLogs_CL\n| where logType_s == \"conn\"\n| extend SrcIp = tostring(src_ip_s), DstIp = tostring(dst_ip_s)\n| extend ThreatIP = case(not(ipv4_is_private(SrcIp)), SrcIp, not(ipv4_is_private(DstIp)), DstIp, \"\")\n| where isnotempty(ThreatIP)\n| extend InternalIP = case(ipv4_is_private(SrcIp), SrcIp, ipv4_is_private(DstIp), DstIp, \"\")\n| summarize ZeekConnHits = count(), ZeekClients = make_set(InternalIP, 10), LastZeek = max(TimeGenerated) by ThreatIP;\nlet FwHits = Syslog\n| where Facility == \"kern\" and SyslogMessage has \"BLOCK\"\n| extend ThreatIP = extract(@'(?:DST|SRC)=([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)', 1, SyslogMessage)\n| extend InternalIP = extract(@'SRC=([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)', 1, SyslogMessage)\n| where isnotempty(ThreatIP) and not(ipv4_is_private(ThreatIP))\n| summarize FwHits = count(), FwClients = make_set(InternalIP, 10), LastFw = max(TimeGenerated) by ThreatIP;\nlet MdeHits = DeviceNetworkEvents\n| where isnotempty(RemoteIP) and not(ipv4_is_private(RemoteIP))\n| summarize MdeHits = count(), MdeDevices = make_set(DeviceName, 10), LastMde = max(TimeGenerated) by ThreatIP = RemoteIP;\nlet DnsResolveHits = ZeekLogs_CL\n| where logType_s == \"dns\" and isnotempty(dns_answers_s)\n| extend Answers = split(dns_answers_s, \",\")\n| mv-expand Answer = Answers\n| extend ThreatIP = trim(@\"\\s\", tostring(Answer))\n| where ThreatIP matches regex @'^\\d+\\.\\d+\\.\\d+\\.\\d+$' and not(ipv4_is_private(ThreatIP))\n| summarize DnsResolveHits = count(), DnsClients = make_set(src_ip_s, 10), LastDns = max(TimeGenerated) by ThreatIP;\nlet PiHoleHits = PiholeDNS_CL\n| extend ThreatIP = extract(@'\\b((?:\\d+\\.){3}\\d+)\\b', 1, _raw_s)\n| where isnotempty(ThreatIP) and not(ipv4_is_private(ThreatIP))\n| extend ClientIP = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s)\n| summarize PiHoleHits = count(), PiHoleClients = make_set(ClientIP, 10), LastPiHole = max(TimeGenerated) by ThreatIP;\nlet MdeIdent = DeviceNetworkInfo\n| summarize arg_max(Timestamp, *) by IPAddresses\n| mv-expand todynamic(IPAddresses)\n| extend InternalIP = tostring(IPAddresses.IPAddress)\n| where ipv4_is_private(InternalIP)\n| project InternalIP, MdeDevice = DeviceName, MdeMac = MacAddress;\nlet DhcpIdent = ZeekLogs_CL\n| where logType_s == \"dhcp\"\n| extend f = split(_raw_s, \"\\t\")\n| extend InternalIP = tostring(f[7]), DhcpHost = tostring(f[10]), DhcpMac = tostring(f[3])\n| where isnotempty(InternalIP) and ipv4_is_private(InternalIP)\n| summarize arg_max(TimeGenerated, *) by InternalIP\n| project InternalIP, DhcpHost, DhcpMac;\nlet Joined = TI\n| join kind=leftouter NetFlowHits on ThreatIP\n| join kind=leftouter ZeekConnHits on ThreatIP\n| join kind=leftouter FwHits on ThreatIP\n| join kind=leftouter MdeHits on ThreatIP\n| join kind=leftouter DnsResolveHits on ThreatIP\n| join kind=leftouter PiHoleHits on ThreatIP\n| extend NetFlowHits = coalesce(NetFlowHits,0), ZeekConnHits = coalesce(ZeekConnHits,0), FwHits = coalesce(FwHits,0), MdeHits = coalesce(MdeHits,0), DnsResolveHits = coalesce(DnsResolveHits,0), PiHoleHits = coalesce(PiHoleHits,0)\n| extend NonMdeHits = NetFlowHits + ZeekConnHits + FwHits + DnsResolveHits + PiHoleHits\n| extend NonMdeOnly = iff(MdeHits == 0 and NonMdeHits > 0, \"Yes\", \"No\")\n| where NonMdeHits > 0 or MdeHits > 0\n| extend AllClients = array_concat(coalesce(NetFlowClients, dynamic([])), coalesce(ZeekClients, dynamic([])), coalesce(FwClients, dynamic([])), coalesce(DnsClients, dynamic([])), coalesce(PiHoleClients, dynamic([])))\n| extend Sources = strcat(iff(NetFlowHits>0,\"NetFlow \",\"\"), iff(ZeekConnHits>0,\"ZeekConn \",\"\"), iff(FwHits>0,\"FW \",\"\"), iff(DnsResolveHits>0,\"ZeekDnsResolve \",\"\"), iff(PiHoleHits>0,\"DnsSinkhole \",\"\"), iff(MdeHits>0,\"MDE\",\"\"))\n| extend LastSeen = max_of(coalesce(LastNetFlow, datetime(1970-01-01)), coalesce(LastZeek, datetime(1970-01-01)), coalesce(LastFw, datetime(1970-01-01)), coalesce(LastMde, datetime(1970-01-01)), coalesce(LastDns, datetime(1970-01-01)), coalesce(LastPiHole, datetime(1970-01-01)));\nJoined\n| mv-expand InternalIP = AllClients to typeof(string)\n| where isnotempty(InternalIP)\n| join kind=leftouter MdeIdent on InternalIP\n| join kind=leftouter DhcpIdent on InternalIP\n| extend ClientName = coalesce(MdeDevice, DhcpHost, InternalIP)\n| extend ClientMac = coalesce(MdeMac, DhcpMac, \"\")\n| extend ClientType = case(isnotempty(MdeDevice), \"MDE Managed\", isnotempty(DhcpHost), \"Non-MDE (DHCP)\", \"Non-MDE (Unknown)\")\n| summarize Clients = make_set(strcat(ClientName, iff(isnotempty(ClientMac), strcat(\" [\",ClientMac,\"]\"), \"\")), 10), ClientTypes = make_set(ClientType, 5), ClientCount = dcount(InternalIP) by ThreatIP, Confidence, TISource, Tags, Sources, NonMdeOnly, NonMdeHits, MdeHits, NetFlowHits, ZeekConnHits, FwHits, DnsResolveHits, PiHoleHits, MdeDevices = tostring(MdeDevices), LastSeen, ValidUntil, Pattern, IndicatorId\n| extend MdeDevices = todynamic(MdeDevices)\n| project ThreatIP, Confidence, TISource, Tags, Sources, NonMdeOnly, NonMdeHits, MdeHits, ClientCount, Clients, ClientTypes, MdeDevices, NetFlowHits, ZeekConnHits, FwHits, DnsResolveHits, PiHoleHits, LastSeen, ValidUntil, Pattern, IndicatorId\n| sort by Confidence desc, NonMdeHits desc\n| top 200 by Confidence",
              "size": 0,
              "title": "TI IP Matches — TII + SecurityAlert IPs vs NetFlow + Zeek + Firewall + MDE + DNS (TI=30d)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Confidence",
                    "formatter": 8,
