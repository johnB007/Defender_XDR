          {
            "type": 3,
            "name": "correlation-ti-hash-matches",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIHash = ThreatIntelIndicators\n| where TimeGenerated > ago(30d) and IsActive == true\n| where ObservableKey in (\"file:hashes.'SHA-256'\",\"file:hashes.'SHA-1'\",\"file:hashes.MD5\")\n| summarize arg_max(TimeGenerated, Confidence, Tags, Pattern, ValidUntil, Id, SourceSystem) by ObservableValue, ObservableKey\n| extend HashLower = tolower(ObservableValue)\n| extend HashType = case(ObservableKey contains \"SHA-256\",\"SHA256\", ObservableKey contains \"SHA-1\",\"SHA1\",\"MD5\")\n| project HashLower, HashType, Confidence = toint(Confidence), Tags = strcat(tostring(SourceSystem), \" | \", tostring(Tags)), Pattern = tostring(Pattern), ValidUntil, IndicatorId = tostring(Id);\nlet MdeFiles = union isfuzzy=true\n  (DeviceFileEvents | project HashLower = tolower(SHA256), HashType=\"SHA256\", TimeGenerated, DeviceName, FileName, FolderPath, ActionType),\n  (DeviceFileEvents | project HashLower = tolower(SHA1), HashType=\"SHA1\", TimeGenerated, DeviceName, FileName, FolderPath, ActionType),\n  (DeviceFileEvents | project HashLower = tolower(MD5), HashType=\"MD5\", TimeGenerated, DeviceName, FileName, FolderPath, ActionType)\n| where isnotempty(HashLower)\n| summarize MdeHits = count(), MdeDevices = make_set(DeviceName, 10), Files = make_set(FileName, 10), LastMde = max(TimeGenerated) by HashLower, HashType;\nTIHash\n| join kind=inner MdeFiles on HashLower, HashType\n| project HashType, Hash = HashLower, Confidence, Tags, MdeHits, MdeDevices, Files, LastMde, ValidUntil, Pattern, IndicatorId\n| sort by Confidence desc, MdeHits desc\n| top 200 by Confidence",
