          {
            "type": 3,
            "name": "correlation-ti-domain-matches",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let TIDom = ThreatIntelIndicators\n| where TimeGenerated > ago(30d) and IsActive == true\n| where ObservableKey == \"domain-name:value\"\n| summarize arg_max(TimeGenerated, Confidence, Tags, Pattern, ValidUntil, Id, SourceSystem) by ObservableValue\n| project Domain = tolower(ObservableValue), Confidence = toint(Confidence), Tags = strcat(tostring(SourceSystem), \" | \", tostring(Tags)), Pattern = tostring(Pattern), ValidUntil, IndicatorId = tostring(Id);\nlet ZeekDns = ZeekLogs_CL\n| where logType_s == \"dns\" and isnotempty(dns_query_s) and dns_query_s != \"-\"\n| extend Domain = tolower(dns_query_s)\n| summarize ZeekDnsHits = count(), ZeekDnsClients = make_set(src_ip_s, 10), LastZeekDns = max(TimeGenerated) by Domain;\nlet ZeekSsl = ZeekLogs_CL\n| where logType_s == \"ssl\"\n| extend f = split(_raw_s, \"\\t\")\n| extend Domain = tolower(tostring(f[9]))\n| where isnotempty(Domain) and Domain != \"-\"\n| summarize ZeekSslHits = count(), LastZeekSsl = max(TimeGenerated) by Domain;\nlet DnsSinkhole = PiholeDNS_CL\n| extend Domain = tolower(coalesce(extract(@'query\\[\\w+\\]\\s+(\\S+)\\s+from', 1, _raw_s), extract(@'(?:cached|forwarded|reply)\\s+(\\S+)\\s+(?:is|to)', 1, _raw_s)))\n| extend ClientIP = extract(@'\\bfrom\\s+(\\d+\\.\\d+\\.\\d+\\.\\d+)', 1, _raw_s)\n| where isnotempty(Domain) and Domain != \"-\"\n| summarize PiHoleHits = count(), PiHoleClients = make_set(ClientIP, 10), LastPiHole = max(TimeGenerated) by Domain;\nlet MdeUrls = DeviceNetworkEvents\n| where isnotempty(RemoteUrl)\n| extend Domain = tolower(extract(@'^(?:https?://)?([^/:?]+)', 1, RemoteUrl))\n| where isnotempty(Domain)\n| summarize MdeHits = count(), MdeDevices = make_set(DeviceName, 10), LastMde = max(TimeGenerated) by Domain;\nTIDom\n| join kind=leftouter ZeekDns on Domain\n| join kind=leftouter ZeekSsl on Domain\n| join kind=leftouter DnsSinkhole on Domain\n| join kind=leftouter MdeUrls on Domain\n| extend ZeekDnsHits = coalesce(ZeekDnsHits, 0), ZeekSslHits = coalesce(ZeekSslHits, 0), PiHoleHits = coalesce(PiHoleHits, 0), MdeHits = coalesce(MdeHits, 0)\n| where ZeekDnsHits > 0 or ZeekSslHits > 0 or PiHoleHits > 0 or MdeHits > 0\n| extend Sources = strcat(iff(ZeekDnsHits>0,\"ZeekDNS \",\"\"), iff(ZeekSslHits>0,\"ZeekSSL \",\"\"), iff(PiHoleHits>0,\"DNS Sinkhole \",\"\"), iff(MdeHits>0,\"MDE\",\"\"))\n| extend Clients = array_concat(coalesce(ZeekDnsClients, dynamic([])), coalesce(PiHoleClients, dynamic([])))\n| extend LastSeen = max_of(coalesce(LastZeekDns, datetime(1970-01-01)), coalesce(LastZeekSsl, datetime(1970-01-01)), coalesce(LastPiHole, datetime(1970-01-01)), coalesce(LastMde, datetime(1970-01-01)))\n| project Domain, Confidence, Tags, Sources, ZeekDnsHits, ZeekSslHits, PiHoleHits, MdeHits, Clients, MdeDevices, LastSeen, ValidUntil, Pattern, IndicatorId\n| sort by Confidence desc, ZeekDnsHits desc\n| top 200 by Confidence",
              "size": 0,
              "title": "TI Domain Matches — TII vs Zeek DNS/SSL + DNS Sinkhole + MDE URLs (TI=30d)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Confidence",
