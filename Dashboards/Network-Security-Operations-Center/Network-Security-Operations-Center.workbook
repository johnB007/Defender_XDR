          {
            "type": 3,
            "name": "wifi-client-session-tracker",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// WiFi Client Tracker - MDE-first, Zeek DHCP fallback, UniFi VAP->SSID static map fallback\nlet StaticSSID = datatable(VAP:string, SSIDName:string)[\n    \"wifi0ap0\",\"WuTangLAN\",   \"wifi1ap2\",\"WuTangLAN\",\n    \"wifi2ap5\",\"WuTangLAN 2\", \"wifi2ap6\",\"WuTangLAN 2\",\n    \"wifi1ap3\",\"WuTangLAN 3\", \"wifi0ap1\",\"WuTangLAN 3\",\n    \"vwireap4\",\"vWire-Backhaul\"\n];\nlet WiFiBase = Syslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| where SyslogMessage has \"[\" and SyslogMessage has \"]\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(MAC)\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| extend VAP = extract(@\"vap-\\d+\\(([^)]+)\\)\", 1, SyslogMessage)\n| extend EventType = case(\n    SyslogMessage has \"recv auth\", \"Auth\",\n    SyslogMessage has \"station associated\", \"Associated\",\n    SyslogMessage has \"disassoc\" or SyslogMessage has \"deauth\", \"Disconnected\",\n    \"Other\");\nlet LastVAPMap = WiFiBase\n| where isnotempty(VAP)\n| summarize arg_max(TimeGenerated, VAP) by MACNorm\n| project MACNorm, LastVAP = VAP;\nlet MACAgg = WiFiBase\n| summarize\n    Events = count(),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated),\n    APs = make_set_if(VAP, isnotempty(VAP), 5),\n    Sessions = countif(EventType == \"Associated\"),\n    Auths = countif(EventType == \"Auth\"),\n    Disconnects = countif(EventType == \"Disconnected\")\n    by MAC, MACNorm;\nlet MdeWifi = DeviceNetworkInfo\n| where TimeGenerated > ago(7d)\n| where NetworkAdapterType contains \"80211\" and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| extend Nets = iff(isnotempty(ConnectedNetworks), parse_json(ConnectedNetworks), dynamic([]))\n| mv-apply n = Nets on (\n    extend SSIDCandidate = tostring(n.Name)\n    | where isnotempty(SSIDCandidate) and SSIDCandidate !startswith \"Unidentified\"\n    | summarize SSID = take_any(SSIDCandidate))\n| summarize arg_max(TimeGenerated, DeviceName, DeviceId, SSID) by MACNorm\n| project MACNorm, MdeDeviceName = DeviceName, DeviceId, MdeSSID = SSID;\nlet MdeIdAny = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| summarize arg_max(TimeGenerated, DeviceName, DeviceId) by MACNorm\n| project MACNorm, AnyDeviceName = DeviceName, AnyDeviceId = DeviceId;\nlet MdeIP = DeviceNetworkInfo\n| where TimeGenerated > ago(7d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| where IPAddr matches regex @\"^(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)\"\n| summarize arg_max(TimeGenerated, IPAddr) by MACNorm\n| project MACNorm, MdeIP = IPAddr;\nlet MdeVendor = DeviceInfo\n| where TimeGenerated > ago(30d)\n| summarize arg_max(Timestamp, Vendor, OnboardingStatus) by DeviceId\n| project DeviceId, MdeVendorName = Vendor, OnboardingStatus;\nlet ZeekDhcpBase = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == \"dhcp\"\n| extend f = split(_raw_s, \"\\t\")\n| extend IP = tostring(f[9]), ReqIP = tostring(f[8]), MAC = tostring(f[4]), HostName = tostring(f[5])\n| where isnotempty(MAC) and MAC != \"-\"\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"));\nlet ZeekDhcpHost = ZeekDhcpBase\n| where isnotempty(HostName) and HostName != \"-\"\n| summarize arg_max(TimeGenerated, HostName) by MACNorm\n| project MACNorm, DhcpHost = HostName;\nlet ZeekDhcpIP = ZeekDhcpBase\n| extend AssignedIP = iff(IP != \"-\" and isnotempty(IP), IP, ReqIP)\n| where isnotempty(AssignedIP) and AssignedIP != \"-\"\n| summarize arg_max(TimeGenerated, AssignedIP) by MACNorm\n| project MACNorm, DhcpIP = AssignedIP;\nMACAgg\n| join kind=leftouter LastVAPMap on MACNorm\n| join kind=leftouter MdeWifi on MACNorm\n| join kind=leftouter MdeIdAny on MACNorm\n| join kind=leftouter MdeVendor on DeviceId\n| join kind=leftouter MdeIP on MACNorm\n| join kind=leftouter ZeekDhcpHost on MACNorm\n| join kind=leftouter ZeekDhcpIP on MACNorm\n| lookup kind=leftouter StaticSSID on $left.LastVAP == $right.VAP\n| extend SecondNibble = substring(MACNorm, 1, 1)\n| extend IsRandomMAC = SecondNibble in (\"2\",\"3\",\"6\",\"7\",\"a\",\"b\",\"e\",\"f\")\n| extend FallbackName = iff(IsRandomMAC, strcat(\"Random-MAC-\", substring(MACNorm, 6, 6)), strcat(\"Unidentified-\", substring(MACNorm, 6, 6)))\n| extend DeviceName = coalesce(MdeDeviceName, AnyDeviceName, DhcpHost, FallbackName)\n| extend IP = coalesce(MdeIP, DhcpIP, \"\")\n| extend SSID = coalesce(MdeSSID, SSIDName, \"\")\n| extend Vendor = coalesce(MdeVendorName, \"\")\n| extend MDEStatus = case(\n    OnboardingStatus == \"Onboarded\",  \"Managed\",\n    isnotempty(MdeDeviceName),        \"Seen by MDE\",\n    isnotempty(AnyDeviceName),        \"MDE (historical)\",\n    isnotempty(DhcpHost),             \"DHCP only\",\n                                      \"Unmanaged\")\n| extend Status = iff(datetime_diff('minute', now(), LastSeen) < 30, \"Online\", \"Offline\")\n| extend DurationMin = datetime_diff('minute', LastSeen, FirstSeen)\n| project\n    MAC, DeviceName, SSID, IP, Vendor, APs,\n    MDEStatus, Status, Sessions, Auths, Disconnects, Events,\n    DurationMin, FirstSeen, LastSeen\n| sort by LastSeen desc\n| take 100",
              "size": 0,
              "title": "WiFi Client Tracker - MDE Enriched (Active & Recent Devices)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Status",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Online",
                          "representation": "green",
                          "text": "Online"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Offline",
                          "representation": "gray",
                          "text": "Offline"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "blue",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "MDEStatus",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Managed",
                          "representation": "green",
                          "text": "Managed"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Seen by MDE",
                          "representation": "blue",
                          "text": "Seen by MDE"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "DHCP only",
                          "representation": "orange",
                          "text": "DHCP only"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Unmanaged",
                          "representation": "redBright",
                          "text": "Unmanaged"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "SessionCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "Events",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "turquoise"
                    }
                  }
                ],
                "filter": true,
                "sortBy": [
                  {
                    "itemKey": "LastSeen",
                    "sortOrder": 2
                  }
                ]
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "wifi-ssid-usage",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// SSID bar chart: MDE real SSID names via MAC correlation, StaticMap fallback\nlet MDEMacToSSID = DeviceNetworkInfo\n| where NetworkAdapterType has \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID = tostring(Networks.Name)\n| where isnotempty(SSID) and SSID !startswith \"Unidentified\"\n| extend MACNorm = tolower(replace_string(MacAddress, \"-\", \"\"))\n| summarize SSID = any(SSID) by MACNorm;\nlet MDEInterfaceSSID =\n    Syslog\n    | where Facility == \"kern\" and Computer == \"IPfreely\" and SyslogMessage has \"vap-\"\n    | extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n    | extend MACNorm = tolower(replace_string(extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage), \":\", \"\"))\n    | where isnotempty(Interface) and isnotempty(MACNorm)\n    | join kind=inner MDEMacToSSID on MACNorm\n    | summarize SSID = any(SSID) by Interface;\nlet UniFiInterfaceSSID = union isfuzzy=true\n    (UniFiSiteManager_Hosts_CL\n    | where tostring(is_wired_b) != \"true\" and isnotempty(essid_s)\n    | extend MACNorm = tolower(replace_string(mac_s, \":\", \"\"))\n    | join kind=inner (\n        Syslog\n        | where Facility == \"kern\" and Computer == \"IPfreely\" and SyslogMessage has \"vap-\"\n        | extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n        | extend MACNorm = tolower(replace_string(extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage), \":\", \"\"))\n        | where isnotempty(Interface) and isnotempty(MACNorm)\n        | summarize Interface = any(Interface) by MACNorm\n    ) on MACNorm\n    | summarize SSID = any(essid_s) by Interface),\n    (datatable(Interface:string, SSID:string)[]);\nlet StaticMap = datatable(Interface:string, SSIDName:string)[\n    \"wifi1ap2\", \"WuTangLAN\",\n    \"wifi0ap0\", \"WuTangLAN\",\n    \"wifi2ap5\", \"WuTangLAN 2\",\n    \"wifi1ap3\", \"WuTangLAN 3\",\n    \"wifi0ap1\", \"WuTangLAN 3\",\n    \"vwireap4\", \"vWire-Backhaul\",\n    \"wifi2ap6\", \"WuTangLAN 2\"\n];\nSyslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| where SyslogMessage has \"vap-\"\n| extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(Interface)\n| lookup kind=leftouter MDEInterfaceSSID on Interface\n| lookup kind=leftouter (UniFiInterfaceSSID | project Interface, SSIDUniFi=SSID) on Interface\n| lookup kind=leftouter StaticMap on Interface\n| extend DisplaySSID = coalesce(SSID, SSIDUniFi, SSIDName, Interface)\n| summarize Connections = count(), UniqueClients = dcount(MAC) by DisplaySSID\n| sort by Connections desc\n| project SSID = DisplaySSID, Connections, UniqueClients\n| render barchart with (kind=unstacked)",
              "size": 1,
              "title": "SSID Usage - Connections by Network",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart"
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-ssid-device-breakdown",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Per-SSID: managed vs unmanaged device counts from MDE\nlet MDEMacToSSID = DeviceNetworkInfo\n| where NetworkAdapterType has \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID = tostring(Networks.Name)\n| where isnotempty(SSID) and SSID !startswith \"Unidentified\"\n| extend MACNorm = tolower(replace_string(MacAddress, \"-\", \"\"))\n| summarize SSID = any(SSID), DeviceName = any(DeviceName), DeviceId = any(DeviceId) by MACNorm;\nlet StaticMap = datatable(Interface:string, SSIDName:string)[\n    \"wifi1ap2\", \"WuTangLAN\",\n    \"wifi0ap0\", \"WuTangLAN\",\n    \"wifi2ap5\", \"WuTangLAN 2\",\n    \"wifi1ap3\", \"WuTangLAN 3\",\n    \"wifi0ap1\", \"WuTangLAN 3\",\n    \"vwireap4\", \"vWire-Backhaul\",\n    \"wifi2ap6\", \"WuTangLAN 2\"\n];\nSyslog\n| where Facility == \"kern\" and Computer == \"IPfreely\" and SyslogMessage has \"vap-\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n| where isnotempty(MAC) and isnotempty(Interface)\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| join kind=leftouter MDEMacToSSID on MACNorm\n| lookup kind=leftouter StaticMap on Interface\n| extend DisplaySSID = coalesce(SSID, SSIDName, Interface)\n| extend MDEManaged = iff(isnotempty(DeviceId), \"Managed\", \"Unmanaged\")\n| summarize UniqueDevices = dcount(MAC) by DisplaySSID, MDEManaged\n| sort by DisplaySSID asc, MDEManaged asc\n| project SSID=DisplaySSID, MDEManaged, UniqueDevices",
              "size": 1,
              "title": "Devices per SSID - Managed vs Unmanaged",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "categoricalbar",
              "chartSettings": {
                "xAxis": "SSID",
                "yAxis": [
                  "UniqueDevices"
                ],
                "splitBy": "MDEManaged",
                "aggregation": "Sum",
                "color": {
                  "Managed": "green",
                  "Unmanaged": "redBright"
                }
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-mde-sessions",
            "content": {
              "version": "KqlItem/1.0",
              "query": "DeviceNetworkInfo\n| where TimeGenerated > ago(7d)\n| where NetworkAdapterType contains \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID = tostring(Networks.Name)\n| extend IsInternet = tobool(Networks.IsConnectedToInternet)\n| extend NetCategory = tostring(Networks.Category)\n| where isnotempty(SSID) and SSID !startswith \"Unidentified\"\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress), AddrType = tostring(ip.AddressType)\n| where AddrType == \"Private\"\n| summarize arg_max(TimeGenerated, MacAddress, IPAddr, IsInternet, NetCategory,\n    NetworkAdapterVendor, DefaultGateways, DnsAddresses, MachineGroup) by DeviceName, DeviceId, SSID\n| extend MAC = replace_string(tostring(MacAddress), \"-\", \":\")\n| extend Gateway = tostring(parse_json(tostring(DefaultGateways))[0])\n| project MAC, DeviceName, SSID, IP = IPAddr, IsInternet, Category = NetCategory,\n    Gateway, DNS = tostring(DnsAddresses), Vendor = NetworkAdapterVendor, MachineGroup, LastSeen = TimeGenerated\n| sort by LastSeen desc",
              "size": 0,
              "title": "MDE WiFi Sessions - Device & Network Details",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "IsInternet",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Internet"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "false",
                          "representation": "failed",
                          "text": "No Internet"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "unknown",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "NetCategory",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Public",
                          "representation": "orange",
                          "text": "Public"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Private",
                          "representation": "green",
                          "text": "Private"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "wifi-ssid-internet-access",
            "content": {
              "version": "KqlItem/1.0",
              "query": "DeviceNetworkInfo\n| where TimeGenerated > ago(7d)\n| where NetworkAdapterType contains \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID = tostring(Networks.Name)\n| extend IsInternet = tobool(Networks.IsConnectedToInternet)\n| where isnotempty(SSID) and SSID !startswith \"Unidentified\"\n| summarize \n    TotalSessions = count(),\n    InternetSessions = countif(IsInternet == true),\n    IsolatedSessions = countif(IsInternet == false),\n    UniqueDevices = dcount(DeviceId)\n    by SSID\n| extend InternetPct = round(toreal(InternetSessions) * 100.0 / toreal(TotalSessions), 1)\n| sort by TotalSessions desc\n| project SSID, UniqueDevices, TotalSessions, InternetSessions, IsolatedSessions, InternetPct",
              "size": 1,
              "title": "SSID Internet Access Summary",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "InternetPct",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "UniqueDevices",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "turquoise"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-signal-quality",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let MDEMacToSSID = DeviceNetworkInfo\n| where NetworkAdapterType has \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID = tostring(Networks.Name)\n| where isnotempty(SSID) and SSID !startswith \"Unidentified\"\n| extend MACNorm = tolower(replace_string(MacAddress, \"-\", \"\"))\n| summarize SSID = any(SSID) by MACNorm;\nlet MDEInterfaceSSID =\n    Syslog\n    | where Facility == \"kern\" and Computer == \"IPfreely\" and SyslogMessage has \"vap-\"\n    | extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n    | extend MACNorm = tolower(replace_string(extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage), \":\", \"\"))\n    | where isnotempty(Interface) and isnotempty(MACNorm)\n    | join kind=inner MDEMacToSSID on MACNorm\n    | summarize SSID = any(SSID) by Interface;\nlet StaticMap = datatable(Interface:string, SSIDName:string)[\n    \"wifi1ap2\", \"WuTangLAN\",\n    \"wifi0ap0\", \"WuTangLAN\",\n    \"wifi2ap5\", \"WuTangLAN 2\",\n    \"wifi1ap3\", \"WuTangLAN 3\",\n    \"wifi0ap1\", \"WuTangLAN 3\",\n    \"vwireap4\", \"vWire-Backhaul\",\n    \"wifi2ap6\", \"WuTangLAN 2\"\n];\nlet MdeNameMap = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| summarize arg_max(TimeGenerated, DeviceName) by MACNorm\n| project MACNorm, MdeName = DeviceName;\nlet ZeekNameMap = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == \"dhcp\"\n| extend f = split(_raw_s, \"\\t\"), M = tostring(split(_raw_s,\"\\t\")[4]), H = tostring(split(_raw_s,\"\\t\")[5])\n| where isnotempty(M) and M != \"-\" and isnotempty(H) and H != \"-\"\n| extend MACNorm = tolower(replace_string(M, \":\", \"\"))\n| summarize arg_max(TimeGenerated, H) by MACNorm\n| project MACNorm, DhcpHost = H;\nSyslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| where SyslogMessage has \"rssi:\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| extend RSSI = toint(extract(@\"rssi:(\\d+)\", 1, SyslogMessage))\n| extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n| lookup kind=leftouter MDEInterfaceSSID on Interface\n| lookup kind=leftouter StaticMap on Interface\n| extend DisplaySSID = coalesce(SSID, SSIDName, Interface)\n| where isnotempty(MAC) and isnotnull(RSSI)\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| summarize AvgRSSI = avg(RSSI), MinRSSI = min(RSSI), MaxRSSI = max(RSSI), Samples = count() by MAC, MACNorm, DisplaySSID\n| join kind=leftouter MdeNameMap on MACNorm\n| join kind=leftouter ZeekNameMap on MACNorm\n| extend SecondNibble = substring(MACNorm, 1, 1)\n| extend IsRandomMAC = SecondNibble in (\"2\",\"3\",\"6\",\"7\",\"a\",\"b\",\"e\",\"f\")\n| extend FallbackName = iff(IsRandomMAC, strcat(\"Random-MAC-\", substring(MACNorm, 6, 6)), strcat(\"Unidentified-\", substring(MACNorm, 6, 6)))\n| extend DeviceName = coalesce(MdeName, DhcpHost, FallbackName)\n| extend SignalQuality = case(\n    AvgRSSI >= 30, \"Excellent\",\n    AvgRSSI >= 20, \"Good\",\n    AvgRSSI >= 10, \"Fair\",\n    \"Poor\")\n| sort by AvgRSSI desc\n| take 50\n| project MAC, DeviceName, SSID=DisplaySSID, SignalQuality, AvgRSSI = round(AvgRSSI, 1), MinRSSI, MaxRSSI, Samples",
              "size": 0,
              "title": "WiFi Signal Quality by Client",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "SignalQuality",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Excellent",
                          "representation": "green",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Good",
                          "representation": "blue",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Fair",
                          "representation": "orange",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Poor",
                          "representation": "redBright",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "AvgRSSI",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "green"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-connection-heatmap",
            "content": {
              "version": "KqlItem/1.0",
              "query": "Syslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| where SyslogMessage has \"[\" and SyslogMessage has \"]\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(MAC)\n| extend EventType = case(\n    SyslogMessage has \"station associated\", \"Connect\",\n    SyslogMessage has \"disassoc\" or SyslogMessage has \"deauth\", \"Disconnect\",\n    SyslogMessage has \"recv auth\", \"Auth\",\n    \"Other\")\n| where EventType in (\"Connect\", \"Disconnect\")\n| summarize Connects = countif(EventType == \"Connect\"), Disconnects = countif(EventType == \"Disconnect\") by bin(TimeGenerated, 1h)\n| extend Churn = Disconnects\n| render areachart with (xtitle=\"Time\", ytitle=\"Events\")",
              "size": 0,
              "title": "WiFi Connect vs Disconnect Activity",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "areachart"
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-mde-device-enrichment",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let StaticMap = datatable(Interface:string, SSIDName:string)[\n    \"wifi1ap2\",\"WuTangLAN\",   \"wifi0ap0\",\"WuTangLAN\",\n    \"wifi2ap5\",\"WuTangLAN 2\", \"wifi2ap6\",\"WuTangLAN 2\",\n    \"wifi1ap3\",\"WuTangLAN 3\", \"wifi0ap1\",\"WuTangLAN 3\",\n    \"vwireap4\",\"vWire-Backhaul\"\n];\nlet WiFiMACs = Syslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(MAC)\n| extend Interface = extract(@\"vap-\\d+\\(([^)]+)\\)\", 1, SyslogMessage)\n| lookup kind=leftouter StaticMap on Interface\n| extend SSIDLocal = coalesce(SSIDName, Interface)\n| where isnotempty(SSIDLocal) and SSIDLocal !in~ (\"unknown\",\"other\",\"<empty>\")\n| summarize WiFiEvents = count(), LastWiFiSeen = max(TimeGenerated),\n    SSIDs = make_set(SSIDLocal, 10) by MAC;\nlet MDEDevices = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| summarize arg_max(TimeGenerated, DeviceName, IPAddr, DeviceId, MachineGroup, NetworkAdapterVendor) by MACNorm\n| project MACNorm, DeviceName, IP = IPAddr, DeviceId, MachineGroup, NetworkAdapterVendor;\nlet MDESSIDJoin = DeviceNetworkInfo\n| where TimeGenerated > ago(7d)\n| where NetworkAdapterType contains \"80211\" and isnotempty(ConnectedNetworks)\n| mv-expand Networks = parse_json(ConnectedNetworks)\n| extend SSID_MDE = tostring(Networks.Name)\n| where isnotempty(SSID_MDE) and SSID_MDE !startswith \"Unidentified\"\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| summarize SSID_MDE = any(SSID_MDE) by MACNorm;\nWiFiMACs\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| join kind=leftouter MDEDevices on MACNorm\n| join kind=leftouter MDESSIDJoin on MACNorm\n| extend SSIDList = iff(isnotempty(SSID_MDE), pack_array(SSID_MDE), SSIDs)\n| extend MDEManaged = iff(isnotempty(DeviceId), \"Yes\", \"No\")\n| extend DeviceName = coalesce(DeviceName, \"\")\n| extend IP = coalesce(IP, \"\")\n| sort by WiFiEvents desc\n| take 100\n| project MAC, DeviceName, SSIDs = SSIDList, IP, Vendor = NetworkAdapterVendor, MachineGroup, MDEManaged, WiFiEvents, LastWiFiSeen",
              "size": 0,
              "title": "WiFi Devices with MDE Enrichment",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "MDEManaged",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Yes",
                          "representation": "green",
                          "text": "Managed"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "No",
                          "representation": "redBright",
                          "text": "Unmanaged"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "WiFiEvents",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "50"
          },
          {
            "type": 3,
            "name": "wifi-roguedevice-detection",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let KnownDeviceThreshold = 3;\nlet MDEMacSet = DeviceNetworkInfo\n| extend MACNorm = tolower(replace_string(MacAddress, \"-\", \"\"))\n| summarize by MACNorm;\nlet StaticMap = datatable(Interface:string, SSIDName:string)[\n    \"wifi1ap2\", \"WuTangLAN\",\n    \"wifi0ap0\", \"WuTangLAN\",\n    \"wifi2ap5\", \"WuTangLAN 2\",\n    \"wifi1ap3\", \"WuTangLAN 3\",\n    \"wifi0ap1\", \"WuTangLAN 3\",\n    \"vwireap4\", \"vWire-Backhaul\",\n    \"wifi2ap6\", \"WuTangLAN 2\"\n];\nlet MdeNameMap = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| summarize arg_max(TimeGenerated, DeviceName) by MACNorm\n| project MACNorm, MdeName = DeviceName;\nlet ZeekNameMap = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == \"dhcp\"\n| extend M = tostring(split(_raw_s,\"\\t\")[4]), H = tostring(split(_raw_s,\"\\t\")[5])\n| where isnotempty(M) and M != \"-\" and isnotempty(H) and H != \"-\"\n| extend MACNorm = tolower(replace_string(M, \":\", \"\"))\n| summarize arg_max(TimeGenerated, H) by MACNorm\n| project MACNorm, DhcpHost = H;\nSyslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(MAC)\n| extend Interface = extract(@\"vap-\\d+\\((\\w+)\\)\", 1, SyslogMessage)\n| lookup kind=leftouter StaticMap on Interface\n| extend SSID = coalesce(SSIDName, Interface)\n| where isnotempty(SSID)\n| summarize \n    Events = count(),\n    FirstSeen = min(TimeGenerated),\n    LastSeen = max(TimeGenerated),\n    SSIDs = make_set(SSID),\n    DaysActive = dcount(bin(TimeGenerated, 1d))\n    by MAC\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| join kind=leftouter MDEMacSet on MACNorm\n| join kind=leftouter MdeNameMap on MACNorm\n| join kind=leftouter ZeekNameMap on MACNorm\n| extend SecondNibble = substring(MACNorm, 1, 1)\n| extend IsRandomMAC = SecondNibble in (\"2\",\"3\",\"6\",\"7\",\"a\",\"b\",\"e\",\"f\")\n| extend FallbackName = iff(IsRandomMAC, strcat(\"Random-MAC-\", substring(MACNorm, 6, 6)), strcat(\"Unidentified-\", substring(MACNorm, 6, 6)))\n| extend DeviceName = coalesce(MdeName, DhcpHost, FallbackName)\n| extend InMDE = iff(isnotempty(MACNorm1), \"Yes\", \"No\")\n| extend DeviceAge_Hours = datetime_diff('hour', now(), FirstSeen)\n| extend Risk = case(\n    InMDE == \"No\" and DaysActive <= 1 and Events < KnownDeviceThreshold, \"New Unmanaged - Investigate\",\n    InMDE == \"No\" and DaysActive <= 1, \"New Unmanaged - Active\",\n    InMDE == \"No\", \"Unmanaged Device\",\n    DaysActive <= 1 and Events < KnownDeviceThreshold, \"New Managed - Investigate\",\n    DaysActive <= 1, \"New Managed - Active\",\n    Events > 500, \"Heavy User\",\n    \"Established\")\n| where Risk !in (\"Established\", \"Heavy User\")\n| sort by FirstSeen desc\n| project MAC, DeviceName, Risk, InMDE, SSIDs, Events, DaysActive, FirstSeen, LastSeen, DeviceAge_Hours",
              "size": 0,
              "title": "New / Rogue Device Detection (MDE-Aware)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Risk",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "contains",
                          "thresholdValue": "Unmanaged - Investigate",
                          "representation": "redBright",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "contains",
                          "thresholdValue": "Unmanaged",
                          "representation": "red",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "contains",
                          "thresholdValue": "Managed - Investigate",
                          "representation": "orange",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "contains",
                          "thresholdValue": "Managed - Active",
                          "representation": "yellow",
                          "text": "{0}{1}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "blue",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "InMDE",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Yes",
                          "representation": "success",
                          "text": "In MDE"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "No",
                          "representation": "failed",
                          "text": "Not in MDE"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "unknown",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  }
                ],
                "filter": true
              }
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "wifi-exec-summary",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// NOC / CISO Executive Summary - one row per tile\nlet MdeMacs = DeviceNetworkInfo\n| where TimeGenerated > ago(7d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),\"-\",\"\"),\":\",\"\"))\n| summarize by MACNorm;\nlet WiFi = Syslog\n| where Facility == \"kern\" and Computer == \"IPfreely\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| where isnotempty(MAC)\n| extend MACNorm = tolower(replace_string(MAC, \":\", \"\"))\n| extend Ev = case(\n    SyslogMessage has \"station associated\", \"Connect\",\n    SyslogMessage has \"deauth\", \"Deauth\",\n    SyslogMessage has \"disassoc\", \"Disconnect\",\n    \"Other\");\nlet Totals = WiFi\n| summarize\n    TotalClients = todouble(dcount(MACNorm)),\n    Deauths = todouble(countif(Ev == \"Deauth\")),\n    OnlineNow = todouble(dcountif(MACNorm, TimeGenerated > ago(30m)));\nlet ManagedMix = WiFi\n| summarize AllMacs = make_set(MACNorm)\n| mv-expand m = AllMacs to typeof(string)\n| extend MACNorm = m\n| join kind=leftouter MdeMacs on MACNorm\n| summarize\n    Managed = todouble(countif(isnotempty(MACNorm1))),\n    Unmanaged = todouble(countif(isempty(MACNorm1)));\nlet Rssi = Syslog\n| where Facility == \"kern\" and Computer == \"IPfreely\" and SyslogMessage has \"rssi:\"\n| extend MAC = extract(@\"\\[([0-9a-fA-F:]{17})\\]\", 1, SyslogMessage)\n| extend RSSI = toint(extract(@\"rssi:(\\d+)\", 1, SyslogMessage))\n| where isnotempty(MAC) and isnotnull(RSSI)\n| summarize Avg = avg(RSSI) by MAC\n| summarize PoorSignal = todouble(countif(Avg < 15));\nlet Combined = Totals | extend _j=1\n| join kind=inner (ManagedMix | extend _j=1) on _j\n| join kind=inner (Rssi | extend _j=1) on _j\n| extend ManagedPct = iff(TotalClients > 0, round(100.0 * Managed / TotalClients, 0), 0.0);\nCombined\n| project TotalClients, OnlineNow, ManagedPct, Unmanaged, Deauths, PoorSignal\n| mv-expand Metric = pack_array(\"Total Clients\",\"Online (30m)\",\"Managed %\",\"Unmanaged\",\"Deauth Events\",\"Poor Signal\") to typeof(string),\n           Value  = pack_array(TotalClients, OnlineNow, ManagedPct, Unmanaged, Deauths, PoorSignal) to typeof(double)\n| project Metric, Value",
              "size": 4,
              "title": "WiFi / LAN Executive Summary",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Value",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "auto",
                    "min": 0
                  },
                  "numberFormat": {
                    "unit": 17,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                },
                "showBorder": true,
                "size": "auto"
              }
            },
            "customWidth": "100"
          }
        ]
      }
    },
    {
      "type": 12,
      "name": "group-zeek",
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Zeek"
      },
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Zeek IDS Deep Analysis\n\n**Network intrusion detection, protocol analysis, and behavioral analytics from Zeek (bridge-mode capture via DNS Sinkhole -> Cribl -> Sentinel)**",
              "style": "info"
            },
            "name": "text-zeek-header"
          },
          {
            "type": 9,
            "name": "zeek-params",
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "zeek-dns-category-id",
                  "version": "KqlParameterItem/1.0",
                  "name": "DnsCategory",
                  "label": "DNS Category",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "jsonData": "[\"User Browsing\",\"SaaS/App Backend\",\"Ads/Tracking\",\"App Telemetry\",\"CDN/Infra\",\"Microsoft/Azure\",\"Google/Firebase\",\"mDNS/Local\",\"Agent/Service GUID\",\"Device Discovery\",\"Other\"]",
                  "value": [
                    "value::all"
                  ]
                },
                {
                  "id": "zeek-dns-device-id",
                  "version": "KqlParameterItem/1.0",
                  "name": "DnsDevice",
                  "label": "Device / Client",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "let MdeNames = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress) and isnotempty(DeviceName)\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| where isnotempty(IPAddr) and IPAddr matches regex @'^(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)'\n| distinct DisplayName = DeviceName;\nlet DhcpNames = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == 'dhcp'\n| extend f = split(_raw_s, '\\t')\n| extend HostName = tostring(f[5])\n| where isnotempty(HostName) and HostName != '-'\n| distinct DisplayName = HostName;\nunion MdeNames, DhcpNames\n| where isnotempty(DisplayName) and not(DisplayName matches regex @'^\\d{1,3}(\\.\\d{1,3}){3}$')\n| distinct DisplayName\n| sort by DisplayName asc",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "queryType": 0,
                  "resourceType": "microsoft.operationalinsights/workspaces",
                  "value": [
                    "value::all"
                  ]
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            }
          },
          {
            "type": 3,
            "name": "zeek-log-types",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let KnownLogTypes = dynamic(['conn','dns','http','ssl','files','quic','dhcp','software','ntp','stats','ocsp','notice','weird','capture_loss','known_services','known_hosts','x509','tunnel','intel','smtp','ftp','ssh','smb','dpd','radius','rdp','irc','modbus','dce_rpc','kerberos','ntlm','mysql','snmp','sip','syslog','telemetry']);\nZeekLogs_CL\n| where TimeGenerated > ago(1d)\n| extend LogType = tostring(logType_s)\n| where isnotempty(LogType)\n| where LogType in (KnownLogTypes)\n| summarize EventCount = count() by LogType\n| top 20 by EventCount\n| render barchart",
              "size": 1,
              "title": "Zeek Log Types Distribution",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "barchart"
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "zeek-event-timeline",
            "content": {
              "version": "KqlItem/1.0",
              "query": "let KnownLogTypes = dynamic(['conn','dns','http','ssl','files','quic','dhcp','software','ntp','stats','ocsp','notice','weird','capture_loss','known_services','known_hosts','x509','tunnel','intel','smtp','ftp','ssh','smb','dpd','radius','rdp','irc','modbus','dce_rpc','kerberos','ntlm','mysql','snmp','sip','syslog','telemetry']);\nZeekLogs_CL\n| extend LogType = tostring(logType_s)\n| where isnotempty(LogType) and LogType in (KnownLogTypes)\n| summarize EventCount = count() by bin(TimeGenerated, {TimeRange:grain}), LogType\n| render timechart with (xtitle='Time', ytitle='Event Count', title='Zeek Event Volume by Log Type')",
              "size": 0,
              "title": "Zeek Event Volume Over Time",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "timechart"
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "zeek-dns-queries",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Top DNS queries from Zeek (bridge-mode capture) - SOC enriched (DeviceName, MAC, SSID, IP, Vendor)\nlet AdsTracking = dynamic(['adnxs.com','rubiconproject.com','chartbeat.net','urbanairship.com','doubleclick.net','scorecardresearch.com','criteo.com','quantserve.com','taboola.com','outbrain.com','adsafeprotected.com','moatads.com','adsystem.com','adsrvr.org','pubmatic.com','openx.net','bidswitch.net','casalemedia.com','adform.net','mediamath.com','turn.com','demdex.net','everesttech.net','adservice.google.com','googlesyndication.com','googleadservices.com','google-analytics.com','analytics.google.com','g.doubleclick.net']);\nlet AppTelemetry = dynamic(['firebaselogging.googleapis.com','safebrowsing.google.com','safebrowsing.googleapis.com','default.exp-tas.com','peoplestack-pa.googleapis.com','arc.msn.com','alive.github.com','api.msn.com','clients.config.office.net','m365cdn.nel.measure.office.net','api.samsungcloud.com','androidwearcloudsync-pa.googleapis.com','ping.chartbeat.net','mtalk.google.com','play.googleapis.com','android.clients.google.com','firebaseinstallations.googleapis.com','firebaseremoteconfig.googleapis.com','fcmtoken.googleapis.com','crashlyticsreports-pa.googleapis.com','app-measurement.com','config.edge.skype.com','nexusrules.officeapps.live.com','self.events.data.microsoft.com','settings-win.data.microsoft.com','watson.telemetry.microsoft.com','vortex.data.microsoft.com','v10.events.data.microsoft.com','insights-collector.newrelic.com','sb-ssl.google.com','update.googleapis.com']);\nlet Browsing = dynamic(['google.com','www.google.com','bing.com','www.bing.com','duckduckgo.com','yahoo.com','youtube.com','www.youtube.com','netflix.com','reddit.com','www.reddit.com','twitter.com','x.com','facebook.com','www.facebook.com','instagram.com','linkedin.com','github.com','www.github.com','stackoverflow.com','amazon.com','www.amazon.com','ebay.com','apple.com','www.apple.com','icloud.com','foxnews.com','cnn.com','www.cnn.com','nytimes.com','bbc.com','www.bbc.com','fidelity.com','www.fidelity.com','schwab.com','chase.com','bankofamerica.com','paypal.com','spotify.com','twitch.tv','www.twitch.tv','wikipedia.org','en.wikipedia.org','msn.com','www.msn.com']);\nlet NoiseRegex = @'(?i)\\.local$|(?i)\\.arpa$|(?i)^_[a-z0-9_-]+\\._(tcp|udp)\\.';\nlet MdeAny = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),'-',''),':',''))\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| where isnotempty(IPAddr) and IPAddr matches regex @'^(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)'\n| extend MdeSsid = tostring(parse_json(tostring(ConnectedNetworks))[0].Name)\n| summarize arg_max(TimeGenerated, DeviceName, DeviceId, MACNorm, NetworkAdapterVendor, MdeSsid) by IP=IPAddr\n| project IP, MdeDeviceName=DeviceName, DeviceId, MACNorm, NicVendor=NetworkAdapterVendor, MdeSsid;\nlet DevInfo = DeviceInfo\n| where TimeGenerated > ago(30d)\n| summarize arg_max(Timestamp, Vendor, OnboardingStatus) by DeviceId\n| project DeviceId, DevVendor=Vendor, OnboardingStatus;\nlet ZeekDhcp = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == 'dhcp'\n| extend f = split(_raw_s, '\\t')\n| extend IP = tostring(f[9]), MAC = tostring(f[4]), HostName = tostring(f[5])\n| where isnotempty(IP) and IP != '-'\n| extend MACNorm = tolower(replace_string(MAC,':',''))\n| summarize arg_max(TimeGenerated, MACNorm, HostName) by IP\n| project IP, DhcpMAC=MACNorm, DhcpHost=HostName;\nlet ApexOf = (d:string) { strcat(tostring(split(d, '.')[-2]), '.', tostring(split(d, '.')[-1])) };\nZeekLogs_CL\n| where logType_s == 'dns'\n| extend Query = tolower(tostring(dns_query_s)), SrcIP = tostring(src_ip_s)\n| where isnotempty(Query) and Query != '-' and isnotempty(SrcIP)\n| extend Apex = ApexOf(Query)\n| extend QueryCategory = case(\n    Query matches regex NoiseRegex, 'mDNS/Local',\n    Query matches regex @'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.', 'Agent/Service GUID',\n    Query has 'googlecast' or Query has 'androidtvremote' or Query has 'rdlink' or Query has 'spotify-connect' or Query has 'airplay' or Query has 'homekit', 'Device Discovery',\n    Query startswith 'api.' or Query startswith 'api-' or Query contains '.api.' or Query contains '-api.' or Query startswith 'apis.' or Query contains 'client-api' or Query contains 'clients.config' or Query startswith 'push.' or Query contains '.push.' or Query startswith 'courier.' or Query contains '-courier.' or Query contains 'courier.push' or Query startswith 'chat-e2ee' or Query startswith 'avs-' or Query startswith 'mtalk.' or Query startswith 'alive.' or Query startswith 'settings.' or Query startswith 'config.' or Query startswith 'configuration.' or Query startswith 'fcmtoken' or Query startswith 'firebaseinstallations' or Query startswith 'firebaseremoteconfig' or Query startswith 'addons-pa' or Query startswith 'appsgenai' or Query startswith 'appsgrowth' or Query startswith 'peoplestack' or Query startswith 'safebrowsing', 'App Telemetry',\n    Query in (AdsTracking) or Apex in (AdsTracking) or Query contains 'doubleclick' or Query contains 'adnxs' or Query contains 'rubiconproject', 'Ads/Tracking',\n    Query in (AppTelemetry) or Apex in (AppTelemetry) or Query contains 'telemetry' or Query contains 'analytics' or Query contains 'logging.google' or Query endswith 'events.data.microsoft.com' or Query endswith 'pipe.aria.microsoft.com', 'App Telemetry',\n    Query in (Browsing) or Apex in (Browsing), 'User Browsing',\n    Query endswith '.microsoft.com' or Query endswith '.azure.com' or Query endswith '.azureedge.net' or Query endswith '.opinsights.azure.com' or Query endswith '.monitor.azure.com' or Query endswith '.windows.net' or Query endswith '.windowsupdate.com' or Query endswith '.arc.azure.com' or Query endswith '.guestconfiguration.azure.com' or Query endswith '.office.net' or Query endswith '.office.com' or Query endswith '.live.com' or Query endswith 'msftconnecttest.com' or Query endswith '.microsoftonline.com' or Query endswith '.msecnd.net' or Query endswith '.msauth.net' or Query endswith '.msftauth.net' or Query endswith '.msn.com' or Query endswith '.skype.com' or Query endswith '.sfbassets.com' or Query endswith '.teams.microsoft.com' or Query endswith '.sharepoint.com' or Query endswith '.onedrive.com' or Query endswith '.xboxlive.com' or Query endswith '.vo.msecnd.net' or Query endswith '.akadns.net' or Query endswith '.bing.com' or Query endswith '.outlook.com' or Query endswith '.hotmail.com', 'Microsoft/Azure',\n    Query endswith '.googleapis.com' or Query endswith '.gstatic.com' or Query endswith '.google.com' or Query endswith '.firebase.com' or Query endswith '.firebaseio.com' or Query endswith '.firebaseapp.com' or Query endswith '.appspot.com' or Query endswith '.firebase-settings.crashlytics.com', 'Google/Firebase',\n    Query endswith '.cloudfront.net' or Query endswith '.akamaiedge.net' or Query endswith '.akamaihd.net' or Query endswith '.akamai.net' or Query endswith '.fastly.net' or Query endswith '.fastlylb.net' or Query endswith '.edgekey.net' or Query endswith '.edgesuite.net' or Query endswith '.cdn.cloudflare.net' or Query endswith '.llnwd.net' or Query endswith 'cribl.io', 'CDN/Infra',\n    'Other')\n| summarize QueryCount=count(), UniqueClients=dcount(SrcIP), ClientIPs=make_set(SrcIP, 25) by Query, QueryCategory\n| where QueryCategory in ({DnsCategory})\n| top 200 by QueryCount\n| mv-expand ClientIP = ClientIPs to typeof(string)\n| join kind=leftouter MdeAny on $left.ClientIP == $right.IP\n| join kind=leftouter DevInfo on DeviceId\n| join kind=leftouter ZeekDhcp on $left.ClientIP == $right.IP\n| extend MACNorm = coalesce(MACNorm, DhcpMAC, '')\n| extend MACFmt = iff(strlen(MACNorm) == 12, strcat(substring(MACNorm,0,2),':',substring(MACNorm,2,2),':',substring(MACNorm,4,2),':',substring(MACNorm,6,2),':',substring(MACNorm,8,2),':',substring(MACNorm,10,2)), '')\n| extend EffDevice = coalesce(MdeDeviceName, DhcpHost, ClientIP)\n| extend EffVendor = coalesce(DevVendor, NicVendor, '')\n| extend EffSSID = coalesce(MdeSsid, '')\n| extend Source = case(\n    OnboardingStatus == 'Onboarded', 'Managed (MDE)',\n    isnotempty(MdeDeviceName), 'Seen by MDE',\n    isnotempty(DhcpHost), 'DHCP only',\n    'Unmanaged')\n| where EffDevice in ({DnsDevice}) or '*' in ({DnsDevice})\n| summarize QueryCount=any(QueryCount), UniqueClients=any(UniqueClients),\n    DeviceNames = make_set_if(EffDevice, isnotempty(EffDevice) and EffDevice != ClientIP, 10),\n    MACs       = make_set_if(MACFmt, isnotempty(MACFmt), 10),\n    Vendors    = make_set_if(EffVendor, isnotempty(EffVendor), 10),\n    SSIDs      = make_set_if(EffSSID, isnotempty(EffSSID), 10),\n    Sources    = make_set_if(Source, isnotempty(Source), 5),\n    ClientIPs  = make_set(ClientIP, 25)\n    by Query, QueryCategory\n| project Domain=Query, Category=QueryCategory, QueryCount, UniqueClients, DeviceNames, MACs, Vendors, SSIDs, Sources, ClientIPs\n| sort by QueryCount desc",
              "size": 0,
              "title": "Top DNS Queries from Zeek (MDE + DHCP + DeviceInfo Enriched)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "QueryCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    },
                    "columnWidth": "70px"
                  },
                  {
                    "columnMatch": "UniqueClients",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "turquoise"
                    }
                  },
                  {
                    "columnMatch": "Category",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "colors",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "User Browsing",
                          "representation": "green",
                          "text": "User Browsing"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "SaaS/App Backend",
                          "representation": "lightBlue",
                          "text": "SaaS/App Backend"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Ads/Tracking",
                          "representation": "redBright",
                          "text": "Ads/Tracking"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "App Telemetry",
                          "representation": "orange",
                          "text": "App Telemetry"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "CDN/Infra",
                          "representation": "gray",
                          "text": "CDN/Infra"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Microsoft/Azure",
                          "representation": "blue",
                          "text": "Microsoft/Azure"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Google/Firebase",
                          "representation": "yellow",
                          "text": "Google/Firebase"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "mDNS/Local",
                          "representation": "lightBlue",
                          "text": "mDNS/Local"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Device Discovery",
                          "representation": "purple",
                          "text": "Device Discovery"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Agent/Service GUID",
                          "representation": "gray",
                          "text": "Agent/Service GUID"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Other",
                          "representation": "gray",
                          "text": "Other"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "gray",
                          "text": "{0}{1}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "DeviceNames",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "MACs",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "SSIDs",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "Vendors",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "Sources",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "ClientIPs",
                    "formatter": 1
                  }
                ],
                "filter": true,
                "sortBy": [
                  {
                    "itemKey": "$gen_heatmap_QueryCount_1",
                    "sortOrder": 2
                  }
                ],
                "rowLimit": 10000
              },
              "sortBy": [
                {
                  "itemKey": "$gen_heatmap_QueryCount_1",
                  "sortOrder": 2
                }
              ]
            },
            "customWidth": "100"
          },
          {
            "type": 3,
            "name": "zeek-http-activity",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Top HTTP activity from Zeek - SOC enriched (DeviceName, MAC, SSID, IP, Vendor)\nlet MdeAny = DeviceNetworkInfo\n| where TimeGenerated > ago(30d) and isnotempty(MacAddress)\n| extend MACNorm = tolower(replace_string(replace_string(tostring(MacAddress),'-',''),':',''))\n| mv-expand ip = parse_json(IPAddresses)\n| extend IPAddr = tostring(ip.IPAddress)\n| where isnotempty(IPAddr) and IPAddr matches regex @'^(192\\.168\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.)'\n| extend MdeSsid = tostring(parse_json(tostring(ConnectedNetworks))[0].Name)\n| summarize arg_max(TimeGenerated, DeviceName, DeviceId, MACNorm, NetworkAdapterVendor, MdeSsid) by IP=IPAddr\n| project IP, MdeDeviceName=DeviceName, DeviceId, MACNorm, NicVendor=NetworkAdapterVendor, MdeSsid;\nlet DevInfo = DeviceInfo\n| where TimeGenerated > ago(30d)\n| summarize arg_max(Timestamp, Vendor, OnboardingStatus) by DeviceId\n| project DeviceId, DevVendor=Vendor, OnboardingStatus;\nlet ZeekDhcp = ZeekLogs_CL\n| where TimeGenerated > ago(30d) and logType_s == 'dhcp'\n| extend f = split(_raw_s, '\\t')\n| extend IP = tostring(f[9]), MAC = tostring(f[4]), HostName = tostring(f[5])\n| where isnotempty(IP) and IP != '-'\n| extend MACNorm = tolower(replace_string(MAC,':',''))\n| summarize arg_max(TimeGenerated, MACNorm, HostName) by IP\n| project IP, DhcpMAC=MACNorm, DhcpHost=HostName;\nZeekLogs_CL\n| where logType_s == 'http'\n| extend f = split(_raw_s, '\\t')\n| extend Host = tostring(f[8]), Method = tostring(f[7]), SrcIP = coalesce(tostring(src_ip_s), tostring(f[2]))\n| where isnotempty(Host) and Host != '-' and isnotempty(SrcIP)\n| summarize RequestCount=count(), UniqueClients=dcount(SrcIP), ClientIPs=make_set(SrcIP, 25) by Host, Method\n| top 100 by RequestCount\n| mv-expand ClientIP = ClientIPs to typeof(string)\n| join kind=leftouter MdeAny on $left.ClientIP == $right.IP\n| join kind=leftouter DevInfo on DeviceId\n| join kind=leftouter ZeekDhcp on $left.ClientIP == $right.IP\n| extend MACNorm = coalesce(MACNorm, DhcpMAC, '')\n| extend MACFmt = iff(strlen(MACNorm) == 12, strcat(substring(MACNorm,0,2),':',substring(MACNorm,2,2),':',substring(MACNorm,4,2),':',substring(MACNorm,6,2),':',substring(MACNorm,8,2),':',substring(MACNorm,10,2)), '')\n| extend EffDevice = coalesce(MdeDeviceName, DhcpHost, '')\n| extend EffVendor = coalesce(DevVendor, NicVendor, '')\n| extend EffSSID  = coalesce(MdeSsid, '')\n| extend Source = case(\n    OnboardingStatus == 'Onboarded', 'Managed (MDE)',\n    isnotempty(MdeDeviceName), 'Seen by MDE',\n    isnotempty(DhcpHost), 'DHCP only',\n    'Unmanaged')\n| summarize RequestCount=any(RequestCount), UniqueClients=any(UniqueClients),\n    DeviceNames = make_set_if(EffDevice, isnotempty(EffDevice), 10),\n    MACs        = make_set_if(MACFmt, isnotempty(MACFmt), 10),\n    Vendors     = make_set_if(EffVendor, isnotempty(EffVendor), 10),\n    SSIDs       = make_set_if(EffSSID, isnotempty(EffSSID), 10),\n    Sources     = make_set_if(Source, isnotempty(Source), 5),\n    ClientIPs   = make_set(ClientIP, 25)\n    by Host, Method\n| project Host, Method, RequestCount, UniqueClients, DeviceNames, MACs, Vendors, SSIDs, Sources, ClientIPs\n| sort by RequestCount desc",
              "size": 0,
              "title": "Top HTTP Activity from Zeek (Identity Enriched)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "RequestCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "turquoise"
                    },
                    "columnWidth": "70px"
                  },
                  {
                    "columnMatch": "UniqueClients",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "DeviceNames",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "MACs",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "SSIDs",
                    "formatter": 1
                  },
                  {
                    "columnMatch": "Vendors",
                    "formatter": 1
                  },
                  {
