    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Global Threat Map\nGeographic visualization of external threat sources. Replace the placeholder query below with your KQL."
            },
            "name": "text-map-header"
          },
          {
            "type": 3,
            "name": "map-visualization",
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Replace with your KQL query\n// Must project: Country, HeatScore, SizeScore, TotalActivity\nprint Country='placeholder', HeatScore=0, SizeScore=0, TotalActivity=0",
              "size": 3,
              "title": "Global Threat Distribution by Country",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "map",
              "mapSettings": {
                "locInfo": "CountryRegion",
                "locInfoColumn": "Country",
                "sizeSettings": "SizeScore",
                "sizeAggregation": "Sum",
                "minSize": 10,
                "maxSize": 60,
                "opacity": 0.85,
                "defaultZoom": 1,
                "autoZoom": false,
                "centerLat": 20,
                "centerLong": 0,
                "labelSettings": "Country",
                "legendMetric": "TotalActivity",
                "legendAggregation": "Sum",
                "numberFormatSettings": {
                  "unit": 0,
                  "options": {
                    "style": "decimal",
                    "useGrouping": true,
                    "maximumFractionDigits": 2,
                    "maximumSignificantDigits": 4
                  }
                },
                "itemColorSettings": {
                  "nodeColorField": "HeatScore",
                  "colorAggregation": "Sum",
                  "type": "heatmap",
                  "heatmapPalette": "yellowOrangeRed"
                }
              }
            },
            "customWidth": "100",
            "customHeight": "900"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "Tab",
        "comparison": "isEqualTo",
        "value": "Map"
      },
      "name": "group-map"
    }
  ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
